{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@scripts/*": ["./src/scripts/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@data/*": ["./src/data/*"],
      "@utils/*": ["./src/utils/*"],
      "@content/*": ["./src/content/*"]
    }
  },
  "exclude": [
    "public",
    "dist",
    "node_modules",
    "test-results"
  ]
}

