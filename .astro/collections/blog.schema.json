{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "series": {
      "type": "string"
    },
    "related": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accent_color": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "ads": {
      "default": true,
      "type": "boolean"
    },
    "toc": {
      "default": true,
      "type": "boolean"
    },
    "manifest": {
      "type": "string"
    },
    "redirect_from": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}