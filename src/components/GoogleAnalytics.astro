---
const GA_ID = import.meta.env.PUBLIC_GA_ID || 'UA-70778035-4';
const IS_PROD = import.meta.env.PROD;
---

{IS_PROD && (
<>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function gtag(){dataLayer.push(arguments);}

        if (!window.__gaInitialized) {
            window.gtag('js', new Date());
            window.__gaInitialized = true;
        }

        const trackPageView = () => {
            window.gtag('config', GA_ID, {
                page_path: window.location.pathname + window.location.search,
            });
        };

        if (!window.__gaPageLoadListener) {
            document.addEventListener('astro:page-load', trackPageView);
            window.__gaPageLoadListener = true;
        }

        trackPageView();
    </script>
</>
)}
