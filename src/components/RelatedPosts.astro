---
/**
 * RelatedPosts.astro
 * Replaces _includes/related_posts.html
 */
import type { CollectionEntry } from 'astro:content';
import { postIdFromSlug, postUrlFromSlug, formatDateUS, getPostDate } from '@utils/posts';

interface Props {
  relatedIds: string[];
  allPosts: CollectionEntry<'blog'>[];
  variant?: string;
}

const { relatedIds, allPosts, variant = '' } = Astro.props;
const BASE = import.meta.env.BASE_URL;

const relatedPosts = relatedIds
  .map(id => allPosts.find(p => postIdFromSlug(p.id) === id))
  .filter(Boolean) as CollectionEntry<'blog'>[];
---
{relatedPosts.length > 0 && (
  <div class={`related-posts-section ${variant}`}>
    <h5 class="related-posts-heading">
      <i class="fas fa-bookmark me-2"></i>You might also like
    </h5>
    <div class="row">
      {relatedPosts.map(post => (
        <div class="col-sm-6 col-md-4 mb-3">
          <a
            href={`${BASE}${postUrlFromSlug(post.id).slice(1)}`}
            class="related-post-link"
            style={post.data.accent_color ? `--card-accent: ${post.data.accent_color}` : undefined}
            aria-label={`Read ${post.data.title}`}
          >
            <div class="card h-100">
              <div class="card-body">
                <p class="card-title mb-1">
                  {post.data.icon && <i class={`${post.data.icon} post-icon me-1`} aria-hidden="true"></i>}
                  {post.data.title}
                </p>
                <small class="related-post-date">{formatDateUS(getPostDate(post))}</small>
              </div>
              <div class="card-footer">
                <small><i class="fas fa-arrow-right me-1"></i>Read more</small>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
)}

<style>
.related-posts-section .related-post-link {
  text-decoration: none;
  display: block;
  color: inherit;
}

.related-posts-section .card {
  transition: transform var(--transition-base), box-shadow var(--transition-base);
  border-radius: 8px;
}

.related-posts-section .card:hover {
  transform: translateY(-4px);
}

/* Shared heading styles for both top and bottom related-posts variants */
.related-posts-section.top-variant .related-posts-heading,
.related-posts-section.bottom-variant .related-posts-heading {
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.75rem;
}

/* Top variant: inside the hero section (blue/info background) */
.related-posts-section.top-variant .related-posts-heading {
  color: rgba(255, 255, 255, 0.85);
}

.related-posts-section.top-variant .card {
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.35);
  color: white;
}

.related-posts-section.top-variant .card:hover {
  background: rgba(255, 255, 255, 0.28);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
}

.related-posts-section.top-variant .card-footer {
  background: rgba(255, 255, 255, 0.1);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
}

.related-posts-section.top-variant .related-post-date {
  color: rgba(255, 255, 255, 0.7);
}

/* Bottom variant: inside the post card body (white background) */
.related-posts-section.bottom-variant .related-posts-heading {
  color: var(--post-accent, var(--color-accent));
}

.related-posts-section.bottom-variant .card {
  background: var(--card-accent, var(--post-accent, var(--color-accent)));
  border: none;
  color: white;
}

.related-posts-section.bottom-variant .card:hover {
  filter: brightness(0.85);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
}

.related-posts-section.bottom-variant .card-footer {
  background: rgba(0, 0, 0, 0.1);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.85);
}

.related-posts-section.bottom-variant .related-post-date {
  color: rgba(255, 255, 255, 0.75);
}

.related-posts-section .card-title {
  font-size: 0.95rem;
  font-weight: 600;
  line-height: 1.3;
}

/* Override icon colour inside related-posts cards (teal background) — inherit white from card */
.related-posts-section .post-icon {
  color: inherit;
  opacity: 1;
}
</style>