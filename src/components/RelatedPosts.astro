---
import type { CollectionEntry } from 'astro:content';
import { postIdFromSlug, postUrlFromSlug, formatDateUS, getPostDate } from '@utils/posts';

interface Props {
  relatedIds: string[];
  allPosts: CollectionEntry<'blog'>[];
}

const { relatedIds, allPosts } = Astro.props;
const BASE = import.meta.env.BASE_URL;

const relatedPosts = relatedIds
  .map(id => allPosts.find(p => postIdFromSlug(p.id) === id))
  .filter(Boolean) as CollectionEntry<'blog'>[];
---
{relatedPosts.length > 0 && (
  <div class="related-posts-section">
    <h5 class="related-posts-heading mb-3 text-uppercase fw-semibold" style="letter-spacing:0.05em; font-size:1rem;">
      <i class="fas fa-bookmark me-2"></i>You might also like
    </h5>
    <div class="d-flex flex-row overflow-auto gap-3 pb-2">
      {relatedPosts.map(post => (
        <div class="flex-shrink-0" style="width:260px; max-width:90vw;">
          <a
            href={`${BASE}${postUrlFromSlug(post.id).slice(1)}`}
            class="d-block text-decoration-none text-reset h-100"
            style={post.data.accent_color ? `--card-accent: ${post.data.accent_color}` : undefined}
            aria-label={`Read ${post.data.title}`}
          >
            <div class="card h-100 d-flex flex-column">
              <div class="card-body flex-grow-1">
                <small class="card-title fw-semibold">
                  {post.data.icon && <i class={`${post.data.icon} me-1 text-white`} aria-hidden="true"></i>}
                  {post.data.title}
                </small>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
)}

<style>
/* Minimal custom CSS for accent backgrounds and icon color */
.related-posts-section .related-posts-heading {
  color: var(--post-accent, var(--color-accent));
}
.related-posts-section .card {
  background: var(--card-accent, var(--post-accent, var(--color-accent)));
  border: none;
  color: white;
}
.related-posts-section .card:hover {
  filter: brightness(0.85);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
}
</style>