---
/**
 * Renders a Pintora diagram to inline SVG at build time.
 * Usage in MDX: <Pintora code={`activityDiagram ...`} />
 */
import { spawnSync } from 'node:child_process';
import { join } from 'node:path';

interface Props {
  code: string;
}

const { code } = Astro.props;

const scriptPath = join(process.cwd(), 'scripts/render-pintora.mjs');
const result = spawnSync('node', [scriptPath], {
  input: code,
  encoding: 'utf8',
  timeout: 10000,
});

const svg = result.status === 0 ? result.stdout.trim() : null;
if (result.status !== 0) {
  console.error('[Pintora] Render failed:', result.stderr, '\nCode:', code);
}
---
{svg ? (
  <div class="pintora-wrapper" set:html={svg} />
) : (
  <pre class="pintora">{code}</pre>
)}
