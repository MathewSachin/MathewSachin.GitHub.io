---
/**
 * Renders a Pintora diagram to inline SVG at build time.
 * Usage in MDX: <Pintora code={`activityDiagram ...`} />
 */
import { render } from '@pintora/cli';

interface Props {
  code: string;
}

const { code } = Astro.props;

async function generateDiagram(code: string) {
  const result = await render({
    code: code,
    mimeType: 'image/svg+xml',
    // THIS IS CRITICAL
    renderInSubprocess: true 
  });
  
  // Returns the raw SVG string
  return result; 
}

const svg = await generateDiagram(code);
---
{svg ? (
  <div class="pintora-wrapper" set:html={svg} />
) : (
  <pre class="pintora">{code}</pre>
)}
