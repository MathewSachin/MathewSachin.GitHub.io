---
import { getCollection } from 'astro:content';
import { postUrlFromSlug } from '@utils/posts';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const postsPromise = getCollection('blog');
const normaliseSlugId = (value: string) => {
  const match = value.match(/^(\d{4})-(\d{1,2})-(\d{1,2})-(.+)$/);
  if (!match) return value;
  const [, year, month, day, rest] = match;
  return `${year}-${Number(month)}-${Number(day)}-${rest}`;
};

const posts = await postsPromise;
const normalizedSlug = normaliseSlugId(slug);
const post = posts.find(entry => normaliseSlugId(entry.id) === normalizedSlug);
if (!post) {
  throw new Error(`No blog post found for slug: ${slug}`);
}

const BASE = import.meta.env.BASE_URL;
const href = `${BASE}${postUrlFromSlug(post.id).slice(1)}`;
---
<a href={href} style={post.data.accent_color ? `color: ${post.data.accent_color};` : undefined}>
  {post.data.icon && <i class={`${post.data.icon} me-1`} aria-hidden="true"></i>}
  {post.data.title}
</a>
