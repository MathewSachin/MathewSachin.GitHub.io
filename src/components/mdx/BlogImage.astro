---
/**
 * BlogImage.astro
 * MDX replacement for {% picture img.jpg alt="..." width="400" %}
 *
 * Images are resolved from /images/<src> (the public/images/ directory).
 *
 * Props:
 *   src   - filename, e.g. "sky_dino.jpg"
 *   alt   - alt text
 *   width - optional width
 *   class - optional CSS classes (default: img-fluid)
 */

interface Props {
  src: string;
  alt?: string;
  width?: string | number;
  class?: string;
}

const { src, alt = '', width, class: className = 'img-fluid' } = Astro.props;
const BASE = import.meta.env.BASE_URL;

// If src is already absolute, use as-is; otherwise prefix with /images/
const imgSrc = src.startsWith('/')
  ? `${BASE}${src.replace(/^\//, '')}`
  : `${BASE}images/${src}`;
---
<img
  src={imgSrc}
  alt={alt}
  class={className}
  {... (width ? { width: String(width) } : {})}
  loading="lazy"
/>
