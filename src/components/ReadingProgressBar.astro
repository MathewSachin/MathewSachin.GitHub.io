<reading-progress-bar role="progressbar" aria-label="Reading progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></reading-progress-bar>

<script>
class ReadingProgressBarElement extends HTMLElement {
  private _onUpdate = () => {
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? Math.min((window.scrollY / docHeight) * 100, 100) : 0;
    this.style.width = progress + "%";
    this.setAttribute("aria-valuenow", String(Math.round(progress)));
  };

  connectedCallback() {
    window.addEventListener("scroll", this._onUpdate, { passive: true });
    window.addEventListener("resize", this._onUpdate);
    this._onUpdate();
  }

  disconnectedCallback() {
    window.removeEventListener("scroll", this._onUpdate);
    window.removeEventListener("resize", this._onUpdate);
  }
}

customElements.define("reading-progress-bar", ReadingProgressBarElement);
</script>

<style>
reading-progress-bar {
  display: block;
  position: fixed;
  top: 0;
  left: 0;
  height: 4px;
  width: 0%;
  background: linear-gradient(90deg, var(--post-accent, var(--color-accent)), #0d6efd);
  z-index: 9999;
  transition: width 0.1s linear;
  pointer-events: none;
}
</style>