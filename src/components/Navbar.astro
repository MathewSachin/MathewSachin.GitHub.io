---
const BASE = import.meta.env.BASE_URL;
---

<site-navbar>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark" style="view-transition-name: navbar;">
  <div class="container">
    <a class="navbar-brand" data-astro-prefetch href={`${BASE}`}>Mathew Sachin</a>
    <button class="navbar-toggler collapsed" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="navbarContent">
      <span class="icon-bar bar-t"></span>
      <span class="icon-bar bar-m"></span>
      <span class="icon-bar bar-b"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" data-astro-prefetch href={`${BASE}blog/`}>Blog</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-astro-prefetch href={`${BASE}tools/`}>Tools</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-astro-prefetch href={`${BASE}privacy_policy/`}>Privacy Policy</a>
          </li>
      </ul>
      <a class="text-light nav-link" data-astro-prefetch href={`${BASE}search/`}><i class="fas fa-search me-1"></i>Search</a>
    </div>
  </div>
</nav>
</site-navbar>
<script>
  class SiteNavbarElement extends HTMLElement {
    private _toggler!: HTMLElement;
    private _content!: HTMLElement;

    private _onToggle = () => {
      this._content.classList.toggle("show");
      this._toggler.classList.toggle("collapsed");
      this._toggler.setAttribute("aria-expanded", this._content.classList.contains("show").toString());
    };

    connectedCallback() {
      this._toggler = this.querySelector(".navbar-toggler")!;
      this._content = this.querySelector("#navbarContent")!;
      this._toggler.addEventListener("click", this._onToggle);
    }

    disconnectedCallback() {
      this._toggler.removeEventListener("click", this._onToggle);
    }
  }

  customElements.define("site-navbar", SiteNavbarElement);
</script>

<style>
site-navbar {
  display: block;
}

.icon-bar {
  width: 25px;
  height: 3px;
  background-color: #B6B6B6;
  display: block;
  transition: all 0.2s;
  margin-top: 5px;
}
.navbar-toggler .bar-t { margin-top: 0; transform: rotate(45deg); transform-origin: left center; }
.navbar-toggler .bar-m { opacity: 0; }
.navbar-toggler .bar-b { transform: rotate(-45deg); transform-origin: left center; }
.navbar-toggler.collapsed .bar-t { transform: rotate(0); }
.navbar-toggler.collapsed .bar-m { opacity: 1; }
.navbar-toggler.collapsed .bar-b { transform: rotate(0); }
</style>
