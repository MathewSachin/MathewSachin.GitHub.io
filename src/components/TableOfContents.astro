---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Filter for h2 and h3 levels
const tocEntries = headings.filter(h => h.depth >= 2 && h.depth <= 3);

// Only show TOC if there are at least 3 entries
const shouldShowToc = tocEntries.length >= 3;

// Group the headings to make rendering nested lists easier
interface GroupedHeading extends MarkdownHeading {
    subheadings: MarkdownHeading[];
}

const groupedEntries = tocEntries.reduce((acc, heading) => {
  if (heading.depth === 2) {
    acc.push({ ...heading, subheadings: [] });
  } else if (heading.depth === 3 && acc.length > 0) {
    acc[acc.length - 1].subheadings.push(heading);
  }
  return acc;
}, [] as GroupedHeading[]);
---

{shouldShowToc && (
<toc-widget class="card toc-card">
  <button
    type="button"
    class="card-header toc-header toc-mobile-toggle w-100 text-start d-md-none"
    aria-expanded="false"
    aria-controls="toc-collapse"
    >
    <small><i class="fas fa-list me-1" aria-hidden="true"></i>Contents</small>
    <i class="fas fa-chevron-down toc-chevron ms-auto" aria-hidden="true"></i>
  </button>
  <div class="card-header toc-header d-none d-md-block">
    <small><i class="fas fa-list me-1" aria-hidden="true"></i>Contents</small>
  </div>
  <div class="collapse d-md-block" id="toc-collapse">
    <div class="card-body p-0">
        <nav id="toc-nav" aria-label="Table of contents">
          <ul class="toc-list">
            {groupedEntries.map((h2) => (
              <li class="toc-link">
                <a href={`#${h2.slug}`}>
                  {h2.text}
                </a>
                
                {h2.subheadings.length > 0 && (
                  <ul class="toc-sublist">
                    {h2.subheadings.map((h3) => (
                      <li class="toc-link toc-h3">
                        <a href={`#${h3.slug}`}>
                          {h3.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
    </div>
  </div>
</toc-widget>
)}

<style>
toc-widget {
  display: block;
}

.toc-card {
  font-size: 0.8rem;
  border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  border-radius: 8px;
  overflow: hidden;
}

.toc-header {
  background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  color: var(--post-accent, var(--color-accent));
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.4rem 0.6rem;
}

#toc-nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

#toc-nav li {
  margin: 0;
  padding: 0;
}

#toc-nav a {
  display: block;
  padding: 0.3rem 0.6rem;
  color: #495057;
  text-decoration: none;
  border-left: 2px solid transparent;
  line-height: 1.35;
  transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

#toc-nav a:hover,
#toc-nav a:focus-visible {
  color: var(--post-accent, var(--color-accent));
  border-left-color: var(--post-accent, var(--color-accent));
  background: color-mix(in srgb, var(--color-accent) 6%, transparent);
}

#toc-nav a.toc-active {
  color: var(--post-accent, var(--color-accent));
  border-left-color: var(--post-accent, var(--color-accent));
  font-weight: 600;
}

#toc-nav .toc-h3 > a {
  padding-left: 1.2rem;
  font-size: 0.75rem;
  color: #6c757d;
}

/* Sublist stays always expanded on mobile */
@media (min-width: 767.99px) {
  /* Sublist Collapse/Expand Transition */
  .toc-sublist {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-in-out;
  }

  .toc-sublist.expanded {
    max-height: 2000px; /* Arbitrary large height to allow smooth transition */
  } 
}

@media (max-width: 767.98px) {
  /* Smooth expand/collapse animation for mobile TOC — use max-height instead
     of Bootstrap's display toggle so we can transition between the two states */
  #toc-collapse.collapse {
    display: block;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  #toc-collapse.collapse.show {
    max-height: 70vh;
    overflow-y: auto;
  }
}

/* Mobile TOC collapsible toggle */
.toc-mobile-toggle {
  display: flex;
  align-items: center;
  border: none;
  cursor: pointer;
}

.toc-mobile-toggle:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.toc-chevron {
  font-size: 0.75rem;
  transition: transform var(--transition-base);
}

.toc-mobile-toggle[aria-expanded="true"] .toc-chevron {
  transform: rotate(180deg);
}
</style>

<script>
// Offset in px to account for the fixed navbar when scroll-spying
const SCROLL_OFFSET = 90;

class TocWidgetElement extends HTMLElement {
  private _abortController: AbortController | undefined;
  private _isClickScrolling = false;
  private _clickScrollTimeout: number | undefined;
  private _manualScrollDebounce: number | undefined;

  connectedCallback() {
    this._abortController = new AbortController();
    const { signal } = this._abortController;

    const tocToggle = this.querySelector(".toc-mobile-toggle") as HTMLElement;
    const tocCollapse = this.querySelector("#toc-collapse") as HTMLElement;
    const tocNav = this.querySelector("#toc-nav") as HTMLElement;
    const tocLinks = tocNav.querySelectorAll("a") as NodeListOf<HTMLAnchorElement>;

    // Helper: update active/expanded state in the TOC nav
    const updateActiveState = (activeId: string | null) => {
      tocLinks.forEach((a) => a.classList.remove("toc-active"));
      tocNav.querySelectorAll(".toc-sublist").forEach((list) => list.classList.remove("expanded"));

      if (activeId) {
        (tocNav.querySelectorAll(`a[href="#${activeId}"]`) as NodeListOf<HTMLAnchorElement>).forEach((a) => {
          a.classList.add("toc-active");
          const isH3 = !!a.parentElement && a.parentElement.classList.contains("toc-h3");
          if (isH3) {
            (a.closest(".toc-sublist") as HTMLElement | null)?.classList.add("expanded");
          } else {
            const sib = a.nextElementSibling as HTMLElement | null;
            if (sib?.classList.contains("toc-sublist")) sib.classList.add("expanded");
          }
        });
      }
    };

    // Mobile TOC collapse toggle
    tocToggle.addEventListener("click", () => {
      const expanded = tocToggle.getAttribute("aria-expanded") === "true";
      tocToggle.setAttribute("aria-expanded", expanded ? "false" : "true");
      tocCollapse.classList.toggle("show");
    }, { signal });

    // Scroll-spy setup
    const tocSidebar = document.getElementById("toc-sidebar") as HTMLElement | null;
    const postContent = document.querySelector("#post .page-content") as HTMLElement | null;
    if (!postContent) return;

    const headings = Array.from(postContent.querySelectorAll("h2, h3")) as HTMLElement[];

    if (headings.length >= 3) {
      if (tocSidebar) tocSidebar.style.display = "";

      const updateToc = () => {
        if (this._isClickScrolling) return;
        if (typeof this._manualScrollDebounce === "number") clearTimeout(this._manualScrollDebounce);
        this._manualScrollDebounce = window.setTimeout(() => {
          const scrollPos = window.scrollY + SCROLL_OFFSET;
          let activeId: string | null = null;
          headings.forEach((h) => {
            if (h.getBoundingClientRect().top + window.scrollY <= scrollPos) activeId = h.id || activeId;
          });
          updateActiveState(activeId);
        }, 50); // Small debounce prevents DOM thrashing if the user rapidly drags the scrollbar
      };

      window.addEventListener("scroll", updateToc, { passive: true, signal });
      window.addEventListener("resize", updateToc, { signal });

      // Initial setup
      updateToc();
    }

    // Track TOC link clicks and manage scroll-pause state
    tocLinks.forEach((a) => {
      a.addEventListener("click", () => {
        const targetHref = a.getAttribute("href") || "";

        // Suspend normal scrollspy behavior briefly to avoid intermediate jumping
        this._isClickScrolling = true;
        if (typeof this._clickScrollTimeout === "number") clearTimeout(this._clickScrollTimeout);
        this._clickScrollTimeout = window.setTimeout(() => {
          this._isClickScrolling = false;
        }, 800); // 800ms typically covers standard smooth scrolling durations

        // Set the target as active immediately
        if (targetHref.startsWith("#")) updateActiveState(targetHref.substring(1));

        // Collapse the TOC on mobile after the user taps a link
        if (tocCollapse.classList.contains("show")) {
          tocCollapse.classList.remove("show");
          tocToggle.setAttribute("aria-expanded", "false");
        }
      }, { signal });
    });
  }

  disconnectedCallback() {
    this._abortController?.abort();
    if (typeof this._manualScrollDebounce === "number") clearTimeout(this._manualScrollDebounce);
    if (typeof this._clickScrollTimeout === "number") clearTimeout(this._clickScrollTimeout);
  }
}

customElements.define("toc-widget", TocWidgetElement);
</script>