---
/**
 * AdUnit.astro
 * Replaces _includes/ad-unit.html and _includes/in-content-ad.html
 */
const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || 'ca-pub-4251360406988977';
const IS_PROD = import.meta.env.PROD;

interface Props {
  slot?: string;
  display?: string;
}
const { slot: adSlot = 'auto', display = 'block' } = Astro.props;
---
{IS_PROD && (
  <div class="in-content-ad google-anno-skip">
    <ins
      class="adsbygoogle"
      style={`display:${display};`}
      data-ad-client={ADSENSE_ID}
      data-ad-slot={adSlot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}

<style>
/* In-content advertisement block */
.in-content-ad {
  overflow: hidden;
  max-width: 100%;
}

.in-content-ad .card {
  box-shadow: none;
  border-color: rgba(0, 0, 0, 0.125);
  overflow: hidden;
}

.in-content-ad ins.adsbygoogle {
  max-width: 100%;
}

/* Hide the whole ad block when AdSense reports the slot is unfilled */
.in-content-ad:has(ins[data-ad-status="unfilled"]) {
  display: none;
}

/* Full-screen-width ads on mobile (below md breakpoint where the TOC sidebar appears) */
@media (max-width: 767.98px) {
  .in-content-ad {
    overflow: visible;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
  }
}
</style>