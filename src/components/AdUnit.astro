---
/**
 * AdUnit.astro
 * Replaces _includes/ad-unit.html and _includes/in-content-ad.html
 */
const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || 'ca-pub-4251360406988977';
const IS_PROD = import.meta.env.PROD;

interface Props {
  slot?: string;
  display?: string;
}
const { slot: adSlot = 'auto', display = 'block' } = Astro.props;
---
{IS_PROD && (
  <div class="in-content-ad google-anno-skip">
    <ins
      class="adsbygoogle"
      style={`display:${display};`}
      data-ad-client={ADSENSE_ID}
      data-ad-slot={adSlot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}
