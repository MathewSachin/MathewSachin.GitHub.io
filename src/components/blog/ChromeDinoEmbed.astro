---
import Fa from 'svelte-fa';
import { faPause, faPlay, faPaperPlane } from '@fortawesome/free-solid-svg-icons';
---

<div class="dino-embed-wrapper">
<iframe id="dino-game-frame" class="dino-embed-frame" src="/dino/index.html" title="Chrome Dino Game — press Space or tap to start" loading="lazy" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
<small class="dino-embed-caption">Chrome Dino game &copy; <a href="https://chromium.googlesource.com/chromium/src/+/refs/heads/main/components/neterror/resources/" target="_blank" rel="noopener">The Chromium Authors</a>, open-sourced under the <a href="https://chromium.googlesource.com/chromium/src/+/refs/heads/main/LICENSE" target="_blank" rel="noopener">BSD 3-Clause License</a>. Extracted by <a href="https://github.com/wayou/t-rex-runner" target="_blank" rel="noopener">@liuwayong</a>.</small>
</div>

<div class="card">
  <div class="card-header align-text-bottom">
    <strong>Live Debugger</strong>
  </div>
  <div class="card-body">
    <button id="debug-toggle" class="btn btn-sm text-info">
      <span id="icon-pause"><Fa icon={faPause} /></span>
      <span id="icon-play" class="d-none"><Fa icon={faPlay} /></span>
    </button>

    <span class="badge rounded-pill bg-primary">
      currentSpeed: <span id="dbg-speed">—</span>
    </span>
    <span class="badge rounded-pill bg-primary">
      tRex.yPos: <span id="dbg-ypos">—</span>
    </span>
    <span class="badge rounded-pill bg-primary">
      <span class="">distanceRan:</span> <span id="dbg-distance">—</span>
    </span>

    <div class="my-3" data-bs-theme="dark">
      <label class="form-label fw-semibold" for="fake-console">Console</label>
      <div class="input-group">  
        <textarea id="fake-console" class="form-control" rows="5"
          placeholder="Type in the commands here and click SEND"></textarea>
        <button class="btn btn-primary" type="button" id="button-dino-send"><Fa icon={faPaperPlane} /> SEND</button>
      </div>
    </div>

  </div>
</div>

<script>
  type DinoRunner = {
    distanceRan?: number;
    distance?: number;
    currentSpeed?: number;
    speed?: number;
    tRex?: { yPos?: number; y?: number };
  };

  type DinoWindow = Window & {
    Runner?: { instance_?: DinoRunner };
    runner?: DinoRunner | null;
    game?: DinoRunner | null;
    distanceRan?: number;
    currentSpeed?: number;
    tRex?: { yPos?: number; y?: number };
    eval?: (code: string) => unknown;
  };
const input = document.getElementById('fake-console') as HTMLTextAreaElement;
const iframe = document.getElementById('dino-game-frame') as HTMLIFrameElement;
const sendButton = document.getElementById('button-dino-send') as HTMLElement;

sendButton.addEventListener('click', function() {
  const command = (input.value || '').trim();
  if (command) {
      try {
        const win = iframe.contentWindow as (Window & Partial<DinoWindow>) | null;
        if (win && typeof win.eval === 'function') {
          win.eval!(command);
        }
      } catch (e) {
      console.warn('Eval failed in iframe:', e);
    }
    input.value = '';
  }
});

const elDistance = document.getElementById('dbg-distance') as HTMLElement;
const elSpeed = document.getElementById('dbg-speed') as HTMLElement;
const elY = document.getElementById('dbg-ypos') as HTMLElement;
const toggleBtn = document.getElementById('debug-toggle') as HTMLElement;
const iconPause = document.getElementById('icon-pause') as HTMLElement;
const iconPlay = document.getElementById('icon-play') as HTMLElement;

let running = true;
let intervalId: number | null = null;

function readVars() {
  const win = iframe.contentWindow as (Window & Partial<DinoWindow>) | null;
  if (!win) return {distance: '—', speed: '—', y: '—'};

  // Common Runner instance (flexible fallbacks)
  type RunnerType = DinoRunner | null;
  const runner: RunnerType = (win && win.Runner && win.Runner.instance_) ? (win.Runner.instance_ as RunnerType) : ((win && (win.runner ?? win.game)) as RunnerType);

  let distance: number | string = '—';
  let speed: number | string = '—';
  let y: number | string = '—';

  try {
    if (runner) {
      distance = (typeof runner.distanceRan !== 'undefined') ? runner.distanceRan as number : (typeof runner.distance === 'number' ? runner.distance : distance);
      speed = (typeof runner.currentSpeed !== 'undefined') ? runner.currentSpeed as number : (typeof runner.speed === 'number' ? runner.speed : speed);
      if (runner.tRex) {
        y = (typeof runner.tRex.yPos !== 'undefined') ? runner.tRex.yPos as number : (typeof runner.tRex.y === 'number' ? runner.tRex.y : y);
      }
    }

    // Some builds expose globals directly
    if (distance === '—' && typeof win?.distanceRan !== 'undefined') distance = (win as DinoWindow).distanceRan as number;
    if (speed === '—' && typeof win?.currentSpeed !== 'undefined') speed = (win as DinoWindow).currentSpeed as number;
    if (y === '—' && typeof win?.tRex !== 'undefined' && typeof (win as DinoWindow).tRex?.yPos !== 'undefined') y = (win as DinoWindow).tRex!.yPos as number;
  } catch (e) {
    // swallow
  }

  // Normalize numbers to short fixed format
  const fmt = (v: unknown) => (typeof v === 'number' ? (v % 1 === 0 ? v : (v as number).toFixed(2)) : v);
  return {distance: fmt(distance), speed: fmt(speed), y: fmt(y)};
}

function update() {
  const vars = readVars();
  elDistance.textContent = String(vars.distance);
  elSpeed.textContent = String(vars.speed);
  elY.textContent = String(vars.y);
}

function start() {
  if (intervalId !== null) return;
  intervalId = window.setInterval(update, 200);
  running = true;
  iconPause.classList.remove('d-none');
  iconPlay.classList.add('d-none');
}

function stop() {
  if (intervalId !== null) window.clearInterval(intervalId);
  intervalId = null;
  running = false;
  iconPause.classList.add('d-none');
  iconPlay.classList.remove('d-none');
}

toggleBtn.addEventListener('click', function(){
  if (running) stop(); else start();
});

// Start polling once iframe has loaded (best-effort)
iframe.addEventListener('load', function(){
  // give the game a small moment to initialize
  setTimeout(() => { update(); start(); }, 300);
});

// Start immediately in case iframe already loaded
setTimeout(() => { update(); start(); }, 500);

// Cleanup on page unload
window.addEventListener('beforeunload', function(){ stop(); });
</script>

<style is:inline>
.dino-embed-wrapper {
  margin: 1rem 0 1.5rem;
  border-radius: 0.5rem;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.dino-embed-frame {
  display: block;
  width: 100%;
  height: 175px;
  border: none;
  background: #f7f7f7;
}

.dino-embed-caption {
  display: block;
  padding: 0.35rem 0.75rem;
  background: var(--color-code-bg);
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.4);
}

.dino-embed-caption a {
  color: rgba(255, 255, 255, 0.55);
}

.dino-embed-caption a:hover {
  color: var(--color-accent);
}
</style>