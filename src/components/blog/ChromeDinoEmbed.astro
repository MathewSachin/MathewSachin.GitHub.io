---
---

<div class="dino-embed-wrapper">
<iframe id="dino-game-frame" class="dino-embed-frame" src="/dino/index.html" title="Chrome Dino Game — press Space or tap to start" scrolling="no" loading="lazy" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
<small class="dino-embed-caption">Chrome Dino game &copy; <a href="https://chromium.googlesource.com/chromium/src/+/refs/heads/main/components/neterror/resources/" target="_blank" rel="noopener">The Chromium Authors</a>, open-sourced under the <a href="https://chromium.googlesource.com/chromium/src/+/refs/heads/main/LICENSE" target="_blank" rel="noopener">BSD 3-Clause License</a>. Extracted by <a href="https://github.com/wayou/t-rex-runner" target="_blank" rel="noopener">@liuwayong</a>.</small>
</div>

<div class="card">
  <div class="card-header align-text-bottom">
    <button id="debug-toggle" class="btn btn-sm text-info"><i class="fas fa-pause"></i></button>
    <strong>Live Debugger</strong>
  </div>
  <div class="card-body">
    <table class="table table-bordered">
      <tr><td><code>distanceRan</code></td><td><span id="dbg-distance">—</span></td></tr>
      <tr><td><code>currentSpeed</code></td><td><span id="dbg-speed">—</span></td></tr>
      <tr><td><code>tRex.yPos</code></td><td><span id="dbg-ypos">—</span></td></tr>
    </table>

    <div class="my-3 console-wrap">
      <label class="form-label fw-semibold" for="fake-console">Console</label>
      <input type="text" id="fake-console" class="form-control"
        placeholder="Type in the commands and press enter">
    </div>
  </div>
</div>

<script>
(function(){
  const input = document.getElementById('fake-console');
  const iframe = document.getElementById('dino-game-frame');
  input.addEventListener('keydown', function(event) {
    if (event.key === 'Enter') {
      const command = this.value.trim();
      if (command) {
        try {
          iframe.contentWindow.eval(command);
        } catch (e) {
          console.warn('Eval failed in iframe:', e);
        }
        this.value = '';
      }
    }
  });

  const elDistance = document.getElementById('dbg-distance');
  const elSpeed = document.getElementById('dbg-speed');
  const elY = document.getElementById('dbg-ypos');
  const toggleBtn = document.getElementById('debug-toggle');
  const toggleIcon = toggleBtn.querySelector('i');

  let running = true;
  let intervalId = null;

  function safeAccessWin() {
    try {
      return iframe && iframe.contentWindow ? iframe.contentWindow : null;
    } catch (e) {
      return null;
    }
  }

  function readVars() {
    const win = safeAccessWin();
    if (!win) return {distance: '—', speed: '—', y: '—'};

    // Common Runner instance (flexible fallbacks)
    const runner = win.Runner && win.Runner.instance_ ? win.Runner.instance_ : (win.runner || win.game || null);

    let distance = '—';
    let speed = '—';
    let y = '—';

    try {
      if (runner) {
        distance = (typeof runner.distanceRan !== 'undefined') ? runner.distanceRan : (typeof runner.distance === 'number' ? runner.distance : distance);
        speed = (typeof runner.currentSpeed !== 'undefined') ? runner.currentSpeed : (typeof runner.speed === 'number' ? runner.speed : speed);
        if (runner.tRex) {
          y = (typeof runner.tRex.yPos !== 'undefined') ? runner.tRex.yPos : (typeof runner.tRex.y === 'number' ? runner.tRex.y : y);
        }
      }

      // Some builds expose globals directly
      if (distance === '—' && typeof win.distanceRan !== 'undefined') distance = win.distanceRan;
      if (speed === '—' && typeof win.currentSpeed !== 'undefined') speed = win.currentSpeed;
      if (y === '—' && typeof win.tRex !== 'undefined' && typeof win.tRex.yPos !== 'undefined') y = win.tRex.yPos;
    } catch (e) {
      // swallow
    }

    // Normalize numbers to short fixed format
    const fmt = v => (typeof v === 'number' ? (v % 1 === 0 ? v : v.toFixed(2)) : v);
    return {distance: fmt(distance), speed: fmt(speed), y: fmt(y)};
  }

  function update() {
    const vars = readVars();
    elDistance.textContent = vars.distance;
    elSpeed.textContent = vars.speed;
    elY.textContent = vars.y;
  }

  function start() {
    if (intervalId) return;
    intervalId = setInterval(update, 200);
    running = true;
    toggleIcon.classList = "fa fa-pause";
  }

  function stop() {
    if (intervalId) clearInterval(intervalId);
    intervalId = null;
    running = false;
    toggleIcon.classList = "fa fa-play";
  }

  toggleBtn.addEventListener('click', function(){
    if (running) stop(); else start();
  });

  // Start polling once iframe has loaded (best-effort)
  iframe.addEventListener('load', function(){
    // give the game a small moment to initialize
    setTimeout(() => { update(); start(); }, 300);
  });

  // Start immediately in case iframe already loaded
  setTimeout(() => { update(); start(); }, 500);

  // Cleanup on page unload
  window.addEventListener('beforeunload', function(){ stop(); });
})();
</script>

<style is:inline>
.dino-embed-wrapper {
  margin: 1rem 0 1.5rem;
  border-radius: 0.5rem;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.dino-embed-frame {
  display: block;
  width: 100%;
  height: 175px;
  border: none;
  background: #f7f7f7;
}

.dino-embed-caption {
  display: block;
  padding: 0.35rem 0.75rem;
  background: var(--color-code-bg);
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.4);
}

.dino-embed-caption a {
  color: rgba(255, 255, 255, 0.55);
}

.dino-embed-caption a:hover {
  color: var(--color-accent);
}
</style>