---
import chromDinoRawStyles from '@styles/chrome-dino-hack.css?raw';
---

<style is:inline set:html={chromDinoRawStyles}></style>

<div class="dino-hack-widget">
    <div class="dino-hack-controls d-flex align-items-center gap-2 flex-wrap px-3 py-2">
        <button class="btn btn-sm btn-dino-reset" id="speed-reset" title="Reset to default" aria-label="Reset speed to default"><i class="fa fa-undo" aria-hidden="true"></i> Reset</button>
        <button class="btn btn-sm btn-dino" id="btn-speed-clip" title="Copy to clipboard" aria-label="Copy code to clipboard"><i class="fa fa-copy" aria-hidden="true"></i> COPY</button>
    </div>
    <div class="dino-hack-controls d-flex align-items-center gap-2 flex-wrap px-3 py-2 small text-white text-opacity-75">
        <span>(Runner.instance_ <span class="code-symbol">||</span> Runner.<span class="code-function">getInstance</span>()).<span class="code-function">setSpeed</span>(</span>
        <input type="number" class="form-control form-control-sm dino-hack-num" id="speed-input" min="0" max="1000" value="50" aria-label="Speed value" />
        <span>)</span>
    </div>
</div>

<script src="@scripts/chrome-dino-hack.js"></script>
<script>
    import { registerCopyToClipboard } from '@scripts/utils.js';

    const clipButton = document.getElementById('btn-speed-clip');
    const speedInput = document.getElementById('speed-input');
    if (clipButton && speedInput) {
        registerCopyToClipboard(
            clipButton, 
            () => `(Runner.instance_ || Runner.getInstance()).setSpeed(${speedInput.value})`,
            clipButton.querySelector("i")
        );
    }
</script>