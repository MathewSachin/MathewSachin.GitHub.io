---
import AdUnit from "@components/AdUnit.astro"
---

<div class="in-content-ad my-4">
  <p class="text-muted text-center mb-2"><small>Advertisement</small></p>
  <div class="card border">
    <div class="card-body p-2">
        <AdUnit/>
    </div>
  </div>
</div>

<style>
/* In-content advertisement block */
.in-content-ad {
  overflow: hidden;
  max-width: 100%;
}

.in-content-ad .card {
  box-shadow: none;
  border-color: rgba(0, 0, 0, 0.125);
  overflow: hidden;
}

.in-content-ad .card-body {
  min-height: 200px; /* Ensure a minimum height for the ad to avoid CLS */
}

.in-content-ad ins.adsbygoogle {
  max-width: 100%;
}

/* Hide the whole ad block when AdSense reports the slot is unfilled */
.in-content-ad:has(ins[data-ad-status="unfilled"]) {
  display: none;
}

/* Full-screen-width ads on mobile (below md breakpoint where the TOC sidebar appears) */
@media (max-width: 767.98px) {
  .in-content-ad {
    overflow: visible;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
  }
}
</style>