---
/**
 * SeriesNav.astro
 * Replaces _includes/series_nav.html
 * Renders prev/next post links for a series (header or footer variant).
 */
import type { CollectionEntry } from 'astro:content';
import { getSeriesPosition } from '@data/index';
import { SERIES } from '@data/series';
import { postIdFromSlug, postUrlFromSlug } from '@utils/posts';

interface Props {
  post: CollectionEntry<'blog'>;
  variant: 'header' | 'footer';
  allPosts: CollectionEntry<'blog'>[];
}

const { post, variant, allPosts } = Astro.props;
const BASE = import.meta.env.BASE_URL;

if (!post.data.series) return null;

const series = SERIES[post.data.series];
if (!series) return null;

const postId = postIdFromSlug(post.id);
const { part, total, prevId, nextId } = getSeriesPosition(series, postId);

const prevPost = prevId ? allPosts.find(p => postIdFromSlug(p.id) === prevId) : null;
const nextPost = nextId ? allPosts.find(p => postIdFromSlug(p.id) === nextId) : null;
---
{variant === 'header' && (
  <div class="series-banner">
    <i class="fas fa-layer-group me-1" aria-hidden="true"></i>
    Part {part} of {total} &mdash;
    <a href={`${BASE}blog/series/${post.data.series}/`}>{series.name}</a> series
    {prevPost && (
      <>
        <br />
        <a class="series-prev-link" href={`${BASE}${postUrlFromSlug(prevPost.id).slice(1)}`}>
          <i class="fas fa-arrow-left me-1" aria-hidden="true"></i>Previous: {prevPost.data.title}
        </a>
      </>
    )}
  </div>
)}

{variant === 'footer' && (prevPost || nextPost) && (
  <div class="series-post-nav" role="navigation" aria-label="Series navigation">
    {prevPost ? (
      <a href={`${BASE}${postUrlFromSlug(prevPost.id).slice(1)}`} class="series-nav-btn prev-post">
        <i class="fas fa-arrow-left nav-icon" aria-hidden="true"></i>
        <div>
          <span class="nav-label">Previous in series</span>
          <span class="nav-title">
            {prevPost.data.icon && <i class={`${prevPost.data.icon} post-icon me-1`} aria-hidden="true"></i>}
            {prevPost.data.title}
          </span>
        </div>
      </a>
    ) : <div></div>}
    {nextPost && (
      <a href={`${BASE}${postUrlFromSlug(nextPost.id).slice(1)}`} class="series-nav-btn next-post">
        <i class="fas fa-arrow-right nav-icon" aria-hidden="true"></i>
        <div>
          <span class="nav-label">Next in series</span>
          <span class="nav-title">
            {nextPost.data.icon && <i class={`${nextPost.data.icon} post-icon me-1`} aria-hidden="true"></i>}
            {nextPost.data.title}
          </span>
        </div>
      </a>
    )}
  </div>
)}

<style>
/* Compact banner shown inside the post header (hero area) */
.series-banner {
  margin-top: 1rem;
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.35);
  border-radius: 6px;
  font-size: 0.875rem;
  color: rgba(255, 255, 255, 0.95);
}

.series-banner a {
  color: #fff;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.series-banner a:hover {
  color: rgba(255, 255, 255, 0.8);
}

.series-banner .series-prev-link {
  display: inline-block;
  margin-top: 0.3rem;
  font-size: 0.8rem;
  opacity: 0.9;
}

/* Prev/Next navigation shown at the bottom of each post */
.series-post-nav {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  gap: 0.75rem;
  margin: 1.25rem 0;
  flex-wrap: wrap;
}

.series-post-nav .series-nav-btn {
  flex: 1 1 calc(50% - 0.4rem);
  min-width: 220px;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  border: 1px solid #dee2e6;
  text-decoration: none;
  color: #333;
  background: #f8f9fa;
  transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  font-size: 0.875rem;
}

.series-post-nav .series-nav-btn:hover {
  background: #e9ecef;
  border-color: var(--color-accent);
  box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 15%, transparent);
  color: var(--color-accent);
}

.series-post-nav .series-nav-btn.next-post {
  flex-direction: row-reverse;
  text-align: right;
  margin-left: auto;
}

.series-post-nav .nav-icon {
  font-size: 1.1rem;
  color: var(--color-accent);
  flex-shrink: 0;
}

.series-post-nav .series-nav-btn:hover .nav-icon {
  color: inherit;
}

.series-post-nav .nav-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #6c757d;
  display: block;
  margin-bottom: 0.15rem;
}

.series-post-nav .nav-title {
  display: block;
  font-weight: 600;
  line-height: 1.3;
}

@media (max-width: 575px) {
  .series-post-nav .series-nav-btn {
    flex: 1 1 100%;
  }
  .series-post-nav .series-nav-btn.next-post {
    flex-direction: row;
    text-align: left;
  }
}
</style>