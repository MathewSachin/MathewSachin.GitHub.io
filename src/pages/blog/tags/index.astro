---
//
// Tags index: /blog/tags/
// Replaces blog/tags/index.html

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { sortPostsByDate, buildTagsMap, tagSlug } from '@utils/posts';
import '@styles/blog.css';

const BASE = import.meta.env.BASE_URL;
const allPosts = sortPostsByDate(await getCollection('blog'));
const tagsMap = buildTagsMap(allPosts);
---
<BaseLayout title="Tags" ads={true}>
  <div class="bg-dark py-3">
    <div class="container">
      <h2 class="text-white mb-3">Tags</h2>

      <div class="card">
        <div class="card-body">
          {[...tagsMap.entries()].map(([tag, posts]) => (
            <div>
            <a href={`${BASE}blog/tags/${tagSlug(tag)}/`} class="tag-post-link text-decoration-none text-reset">
              <div class="tag-post-item d-flex justify-content-between align-items-center">
                <div class="p-2 flex-grow-1">{tag}</div>
                <div class="p-2"><span class="badge bg-info ms-1">{posts.length}</span></div>
              </div>
            </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
