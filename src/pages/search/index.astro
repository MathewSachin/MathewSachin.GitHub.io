---
//
// Search page: /search/
// Replaces search/index.html

import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/blog.css';
const BASE = import.meta.env.BASE_URL;
---
<BaseLayout title="Search">
  <div class="bg-dark py-3">
    <div class="container">
      <h2 class="text-white mb-3">Search</h2>

      <div class="card">
        <div class="card-body">
          <div id="search-status" class="text-muted small mb-3">
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            Loading search index&hellip;
          </div>

          <div class="input-group mb-4">
            <span class="input-group-text bg-info text-white border-info"><i class="fas fa-search"></i></span>
            <input
              id="search-input"
              type="search"
              class="form-control form-control-lg"
              placeholder="Search posts and tools&hellip;"
              aria-label="Search posts and tools"
              disabled
              autocomplete="off"
            />
          </div>

          <div id="search-results"></div>

          <p class="text-muted small mt-4">
            Curious how this search works?
            <a href={`${BASE}blog/2026/03/25/how-site-search-works.html`}>Read the post — fully offline, no server required.</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  {/* Inject base URL for use by search.js (replaces Jekyll's {{ site.baseurl }}) */}
  <script set:html={`window.SEARCH_BASE = ${JSON.stringify(BASE)};`}></script>
  <script src='@scripts/search.js'></script>
</BaseLayout>
