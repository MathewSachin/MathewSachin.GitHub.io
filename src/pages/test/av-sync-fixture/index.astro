---
// AV-Sync Test Fixture
// This page provides a deterministic synthetic A/V stream for Playwright-based
// synchronization tests.  It is not linked from any production page.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>AV Sync Test Fixture</title>
</head>
<body>
  <p id="status">idle</p>

  <script>
    // ── AV Sync Test Fixture ────────────────────────────────────────────────────
    // Exposes window.__avSyncFixture = { start(opts?), stop() }
    //
    // start(opts?)
    //   opts.vfr {boolean} — when true, pauses the frame loop for 1500 ms
    //                        AFTER the 4th pulse has completed (Scenario C).
    //                        The 5th pulse therefore lands at ~5.5 s rather than
    //                        ~5.0 s, verifying that the muxer respects absolute
    //                        timestamps instead of assuming a fixed frame rate.
    //
    // stop()  — finalises the recording, flushes the OPFS file, and resolves.
    //           The Playwright test then reads "av-sync-test.webm" from OPFS.
    //
    // Design notes
    // ─────────────────────────────────────────────────────────────────────────
    // • Canvas: 640×360 @ 30 fps.  Resolution-independent for sync testing;
    //   chosen to keep CI encode time manageable (the spec suggests 1920×1080/
    //   60 fps but that property is orthogonal to timestamp correctness).
    // • Timing: a dedicated Web Worker running a setTimeout loop drives the
    //   encode cadence.  Worker timers are not throttled in background tabs
    //   (unlike main-thread setTimeout or requestAnimationFrame), so Scenario D
    //   correctly exercises the muxer under background conditions.
    // • Audio: OscillatorNode (1 kHz) → GainNode (0 by default) →
    //   MediaStreamDestination → MediaStreamAudioTrackSource.  Each pulse
    //   schedules gain 0→1→0 for one frame duration via AudioContext.
    // • Timestamps: each frame is encoded with (performance.now() − startTime)
    //   seconds so video timestamps reflect true wall-clock time regardless of
    //   frame-loop pauses (Scenario C) or CPU throttling (Scenario B).
    // • Output: StreamTarget → OPFS "av-sync-test.webm".  mediabunny's
    //   output.finalize() closes the underlying WritableStream, committing the
    //   file before stop() resolves.

    import {
      Output,
      WebMOutputFormat,
      StreamTarget,
      CanvasSource,
      MediaStreamAudioTrackSource,
    } from 'mediabunny';

    // ── Constants ───────────────────────────────────────────────────────────────
    const CANVAS_W       = 640;
    const CANVAS_H       = 360;
    const TARGET_FPS     = 30;
    const FRAME_MS       = Math.round(1000 / TARGET_FPS);  // 33 ms
    const PULSE_INTERVAL = 1000;                           // ms between flashes
    const PULSE_DURATION = FRAME_MS;                       // one-frame white flash
    const VFR_AFTER_N    = 4;   // Scenario C: pause AFTER the Nth pulse
    const VFR_PAUSE_MS   = 1500;

    const statusEl = document.getElementById('status');
    const setStatus = s => { if (statusEl) statusEl.textContent = s; };

    // ── Worker timer ─────────────────────────────────────────────────────────────
    // A single shared worker drives all frame-pacing sleeps.  It is safe to
    // reuse because frameLoop() is sequential — each iteration awaits its sleep
    // before starting the next — and stop() awaits loopPromise directly rather
    // than calling workerSleep, so there is never more than one outstanding
    // onmessage handler at a time.
    const _timerBlob = new Blob(
      ['let t;self.onmessage=function(e){clearTimeout(t);t=setTimeout(function(){self.postMessage(null);},e.data);}'],
      { type: 'application/javascript' },
    );
    const _timerUrl    = URL.createObjectURL(_timerBlob);
    const _timerWorker = new Worker(_timerUrl);
    URL.revokeObjectURL(_timerUrl);

    function workerSleep(ms) {
      return new Promise(resolve => {
        _timerWorker.onmessage = () => { _timerWorker.onmessage = null; resolve(); };
        _timerWorker.postMessage(Math.max(0, ms));
      });
    }

    // ── Canvas ──────────────────────────────────────────────────────────────────
    const canvas  = document.createElement('canvas');
    canvas.width  = CANVAS_W;
    canvas.height = CANVAS_H;
    canvas.style.cssText = 'display:none';
    document.body.appendChild(canvas);
    const ctx2d = canvas.getContext('2d');

    // ── Module state ─────────────────────────────────────────────────────────────
    let recording    = false;
    let loopPromise  = null;   // resolves when frameLoop() exits
    let startTimeMs  = 0;
    let nextPulseMs  = PULSE_INTERVAL;
    let pulseEndMs   = -1;
    let pulsesFired  = 0;
    let vfrEnabled   = false;
    let vfrDone      = false;
    let output       = null;
    let canvasSource = null;
    let audioCtx     = null;
    let gainNode     = null;

    // ── Frame loop ───────────────────────────────────────────────────────────────
    async function frameLoop() {
      while (recording) {
        const frameStart = performance.now();
        const elapsed    = frameStart - startTimeMs;  // ms since record start

        // ① Start a new pulse?
        if (elapsed >= nextPulseMs && pulseEndMs < 0) {
          pulseEndMs   = elapsed + PULSE_DURATION;
          nextPulseMs += PULSE_INTERVAL;
          pulsesFired += 1;

          // Schedule audio tone exactly in sync with this white frame
          const when = audioCtx.currentTime;
          gainNode.gain.cancelScheduledValues(when);
          gainNode.gain.setValueAtTime(1, when);
          gainNode.gain.setValueAtTime(0, when + PULSE_DURATION / 1000);
        }

        // ② Draw the canvas frame
        const inPulse = pulseEndMs > 0 && elapsed < pulseEndMs;
        if (pulseEndMs > 0 && elapsed >= pulseEndMs) pulseEndMs = -1;
        ctx2d.fillStyle = inPulse ? '#ffffff' : '#000000';
        ctx2d.fillRect(0, 0, CANVAS_W, CANVAS_H);

        // ③ Encode — timestamp = true elapsed seconds so it is wall-clock
        //    accurate even when the loop was paused (Scenario C) or the CPU
        //    was throttled (Scenario B).
        await canvasSource.add(elapsed / 1000);

        if (!recording) break;

        // ④ Scenario C (VFR): pause AFTER the Nth pulse's flash has ended,
        //    simulating a static screen where the browser stops emitting frames.
        if (vfrEnabled && !vfrDone && pulsesFired >= VFR_AFTER_N && pulseEndMs < 0) {
          vfrDone = true;
          setStatus('vfr-pause');
          await workerSleep(VFR_PAUSE_MS);
          if (!recording) break;
          setStatus('recording');
        }

        // ⑤ Sleep until the next frame
        const cost = performance.now() - frameStart;
        await workerSleep(Math.max(0, FRAME_MS - cost));
      }
    }

    // ── Public: start ────────────────────────────────────────────────────────────
    async function start(opts = {}) {
      if (recording) throw new Error('av-sync-fixture: already recording');

      vfrEnabled  = Boolean(opts.vfr);
      vfrDone     = false;
      nextPulseMs = PULSE_INTERVAL;
      pulseEndMs  = -1;
      pulsesFired = 0;

      setStatus('starting');

      // Web Audio: OscillatorNode → GainNode (0) → MediaStreamDestination
      audioCtx = new AudioContext();
      const osc = audioCtx.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = 1000;
      gainNode = audioCtx.createGain();
      gainNode.gain.value = 0;
      const dest = audioCtx.createMediaStreamDestination();
      osc.connect(gainNode);
      gainNode.connect(dest);
      osc.start();
      const audioTrack = dest.stream.getAudioTracks()[0];

      // OPFS output file
      const opfsRoot = await navigator.storage.getDirectory();
      try { await opfsRoot.removeEntry('av-sync-test.webm'); } catch (_) {}
      const fh = await opfsRoot.getFileHandle('av-sync-test.webm', { create: true });
      const ws = await fh.createWritable();

      // mediabunny pipeline
      output = new Output({
        format: new WebMOutputFormat(),
        target: new StreamTarget(ws),
      });
      canvasSource = new CanvasSource(canvas, { codec: 'vp9', bitrate: 4_000_000 });
      output.addVideoTrack(canvasSource);

      const audioSource = new MediaStreamAudioTrackSource(
        audioTrack, { codec: 'opus', bitrate: 128_000 },
      );
      output.addAudioTrack(audioSource);

      await output.start();

      recording   = true;
      startTimeMs = performance.now();
      setStatus('recording');

      // Store the loop promise so stop() can await it cleanly
      loopPromise = frameLoop().catch(err => {
        console.error('[av-sync-fixture] frameLoop error:', err);
        setStatus('error:' + String(err));
      });
    }

    // ── Public: stop ─────────────────────────────────────────────────────────────
    async function stop() {
      if (!recording) throw new Error('av-sync-fixture: not recording');
      recording = false;
      setStatus('stopping');

      // Wait for the current frame iteration to finish
      await loopPromise;

      await output.finalize();  // flushes and closes the OPFS WritableStream
      output = canvasSource = null;
      if (audioCtx) { audioCtx.close(); audioCtx = null; }

      setStatus('done');
    }

    window.__avSyncFixture = { start, stop };
    setStatus('ready');
  </script>
</body>
</html>
