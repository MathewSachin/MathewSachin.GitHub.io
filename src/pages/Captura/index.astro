---
// Redirect /Captura/ → /tools/captura/
// Mirrors Jekyll's redirect_from: [/Captura/] in tools/captura/index.html
const target = `${import.meta.env.BASE_URL}tools/captura/`;
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="refresh" content={`0; url=${target}`}>
    <link rel="canonical" href={target}>
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Captura Web Recorder</a>…</p>
    <script set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </body>
</html>
