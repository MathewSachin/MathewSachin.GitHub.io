---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/timestamp.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="Timestamp Converter" ads={true}>

<div class="card google-anno-skip">
<div class="card-body">

<div class="row g-4">

  <!-- DateTime to Epoch -->
  <div class="col-12 col-md-6">
    <h5 class="mb-3">Date / Time &rarr; Epoch</h5>
    <div class="mb-3">
      <label for="dt-input" class="form-label">Date &amp; Time (local)</label>
      <input type="datetime-local" id="dt-input" class="form-control">
    </div>

    <div id="dt-result" class="mt-3 d-none">
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">Seconds:</span>
        <code id="dt-seconds"></code>
        <button class="btn btn-sm btn-outline-secondary" id="dt-copy-seconds" title="Copy seconds">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="text-muted">Milliseconds:</span>
        <code id="dt-millis"></code>
        <button class="btn btn-sm btn-outline-secondary" id="dt-copy-millis" title="Copy milliseconds">
          <i class="fas fa-copy"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Epoch to DateTime -->
  <div class="col-12 col-md-6">
    <h5 class="mb-3">Epoch &rarr; Date / Time</h5>
    <div class="mb-3">
      <label for="epoch-input" class="form-label">Unix Timestamp</label>
      <input type="number" id="epoch-input" class="form-control" placeholder="e.g. 1700000000">
      <div class="form-text">Enter seconds or milliseconds &mdash; auto-detected.</div>
    </div>

    <div id="epoch-result" class="mt-3 d-none">
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">UTC:</span>
        <code id="epoch-utc"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-utc" title="Copy UTC">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">Local:</span>
        <code id="epoch-local"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-local" title="Copy local">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="text-muted">ISO&nbsp;8601:</span>
        <code id="epoch-iso"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-iso" title="Copy ISO 8601">
          <i class="fas fa-copy"></i>
        </button>
      </div>
    </div>
  </div>

</div>

<!-- Current timestamp ticker -->
<hr class="mt-4 mb-3">
<h5 class="mb-3">Current Time</h5>
<div class="row row-cols-auto g-3">
  <div class="col">
    <span class="text-muted me-1">Seconds:</span><code id="now-seconds"></code>
  </div>
  <div class="col">
    <span class="text-muted me-1">Milliseconds:</span><code id="now-millis"></code>
  </div>
  <div class="col">
    <span class="text-muted me-1">UTC:</span><code id="now-utc"></code>
  </div>
</div>

<script>
import { epochToMs, datetimeLocalToMs } from '@scripts/tools/timestamp.js';
import { registerCopyToClipboard } from '@scripts/utils.js';

// --- DateTime → Epoch ---
var dtInput = document.getElementById('dt-input') as HTMLInputElement;
var dtResult = document.getElementById('dt-result') as HTMLElement;
var dtSeconds = document.getElementById('dt-seconds') as HTMLElement;
var dtMillis = document.getElementById('dt-millis') as HTMLElement;

// Pre-fill with the current local time
var now = new Date();
if (dtInput) dtInput.value = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);

function updateDt() {
  var val = dtInput.value;
  if (!val) {
    dtResult.classList.add('d-none');
    return;
  }
  var ms = datetimeLocalToMs(val);
  dtSeconds.textContent = Math.floor(ms / 1000).toString();
  dtMillis.textContent = ms.toString();
  dtResult.classList.remove('d-none');
}

if (dtInput) {
  dtInput.addEventListener('input', updateDt);
  dtInput.addEventListener('change', updateDt);
}
updateDt(); // initial conversion on page load

const copySecondsBtn = document.getElementById('dt-copy-seconds') as HTMLElement;
const copyMillisBtn = document.getElementById('dt-copy-millis') as HTMLElement;
if (copySecondsBtn) registerCopyToClipboard(copySecondsBtn, () => dtSeconds.textContent, copySecondsBtn.querySelector('i'));
if (copyMillisBtn) registerCopyToClipboard(copyMillisBtn, () => dtMillis.textContent, copyMillisBtn.querySelector('i'));

// --- Epoch → DateTime ---
var epochInput = document.getElementById('epoch-input') as HTMLInputElement;
var epochResult = document.getElementById('epoch-result') as HTMLElement;
var epochUtc = document.getElementById('epoch-utc') as HTMLElement;
var epochLocal = document.getElementById('epoch-local') as HTMLElement;
var epochIso = document.getElementById('epoch-iso') as HTMLElement;

function updateEpoch() {
  var raw = epochInput ? epochInput.value.trim() : '';
  if (!raw) {
    epochResult.classList.add('d-none');
    return;
  }
  var n = parseInt(raw, 10);
  if (Number.isNaN(n)) {
    epochResult.classList.add('d-none');
    return;
  }
  var ms = epochToMs(n);
  var d = new Date(ms);
  epochUtc.textContent = d.toUTCString();
  epochLocal.textContent = d.toLocaleString();
  epochIso.textContent = d.toISOString();
  epochResult.classList.remove('d-none');
}

if (epochInput) {
  epochInput.addEventListener('input', updateEpoch);
  epochInput.addEventListener('change', updateEpoch);
}

const copyUtcBtn = document.getElementById('epoch-copy-utc') as HTMLElement;
const copyLocalBtn = document.getElementById('epoch-copy-local') as HTMLElement;
const copyIsoBtn = document.getElementById('epoch-copy-iso') as HTMLElement;
if (copyUtcBtn) registerCopyToClipboard(copyUtcBtn, () => epochUtc.textContent, copyUtcBtn.querySelector('i'));
if (copyLocalBtn) registerCopyToClipboard(copyLocalBtn, () => epochLocal.textContent, copyLocalBtn.querySelector('i'));
if (copyIsoBtn) registerCopyToClipboard(copyIsoBtn, () => epochIso.textContent, copyIsoBtn.querySelector('i'));

// --- Live clock ---
function tick() {
  var t = new Date();
  var ms = t.getTime();
  var nowSeconds = document.getElementById('now-seconds') as HTMLElement;
  var nowMillis = document.getElementById('now-millis') as HTMLElement;
  var nowUtc = document.getElementById('now-utc') as HTMLElement;
  if (nowSeconds) nowSeconds.textContent = Math.floor(ms / 1000).toString();
  if (nowMillis) nowMillis.textContent = ms.toString();
  if (nowUtc) nowUtc.textContent = t.toUTCString();
}
tick();
setInterval(tick, 1000);
</script>

</div>
</div>

<RenderMDX Content={Content} />
</ToolLayout>
