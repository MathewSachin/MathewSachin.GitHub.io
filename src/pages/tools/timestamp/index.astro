---
import ToolLayout from '@layouts/ToolLayout.astro';
import { epochToMs, datetimeLocalToMs } from './timestamp.js';
import Docs from '@content/tool-docs/timestamp.mdx';
---
<ToolLayout title="Timestamp Converter" ads={true}>

<div class="card google-anno-skip">
<div class="card-body">

<div class="row g-4">

  <!-- DateTime to Epoch -->
  <div class="col-12 col-md-6">
    <h5 class="mb-3">Date / Time &rarr; Epoch</h5>
    <div class="mb-3">
      <label for="dt-input" class="form-label">Date &amp; Time (local)</label>
      <input type="datetime-local" id="dt-input" class="form-control">
    </div>
    <button class="btn btn-info text-white" id="dt-convert-btn">Convert</button>

    <div id="dt-result" class="mt-3 d-none">
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">Seconds:</span>
        <code id="dt-seconds"></code>
        <button class="btn btn-sm btn-outline-secondary" id="dt-copy-seconds" title="Copy seconds">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="text-muted">Milliseconds:</span>
        <code id="dt-millis"></code>
        <button class="btn btn-sm btn-outline-secondary" id="dt-copy-millis" title="Copy milliseconds">
          <i class="fas fa-copy"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Epoch to DateTime -->
  <div class="col-12 col-md-6">
    <h5 class="mb-3">Epoch &rarr; Date / Time</h5>
    <div class="mb-3">
      <label for="epoch-input" class="form-label">Unix Timestamp</label>
      <input type="number" id="epoch-input" class="form-control" placeholder="e.g. 1700000000">
      <div class="form-text">Enter seconds or milliseconds &mdash; auto-detected.</div>
    </div>
    <button class="btn btn-info text-white" id="epoch-convert-btn">Convert</button>

    <div id="epoch-result" class="mt-3 d-none">
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">UTC:</span>
        <code id="epoch-utc"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-utc" title="Copy UTC">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
        <span class="text-muted">Local:</span>
        <code id="epoch-local"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-local" title="Copy local">
          <i class="fas fa-copy"></i>
        </button>
      </div>
      <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="text-muted">ISO&nbsp;8601:</span>
        <code id="epoch-iso"></code>
        <button class="btn btn-sm btn-outline-secondary" id="epoch-copy-iso" title="Copy ISO 8601">
          <i class="fas fa-copy"></i>
        </button>
      </div>
    </div>
  </div>

</div>

<!-- Current timestamp ticker -->
<hr class="mt-4 mb-3">
<h5 class="mb-3">Current Time</h5>
<div class="row row-cols-auto g-3">
  <div class="col">
    <span class="text-muted me-1">Seconds:</span><code id="now-seconds"></code>
  </div>
  <div class="col">
    <span class="text-muted me-1">Milliseconds:</span><code id="now-millis"></code>
  </div>
  <div class="col">
    <span class="text-muted me-1">UTC:</span><code id="now-utc"></code>
  </div>
</div>

<script type="module">
import { epochToMs, datetimeLocalToMs } from './timestamp.js';

// Utility: copy text and briefly swap icon to a check mark
function copyText(text, btn) {
  navigator.clipboard.writeText(text).then(function () {
    var icon = btn.querySelector('i');
    icon.className = 'fas fa-check text-success';
    setTimeout(function () { icon.className = 'fas fa-copy'; }, 1500);
  }).catch(function () {
    var icon = btn.querySelector('i');
    icon.className = 'fas fa-times text-danger';
    setTimeout(function () { icon.className = 'fas fa-copy'; }, 1500);
  });
}

// --- DateTime → Epoch ---
var dtInput = document.getElementById('dt-input');
var dtResult = document.getElementById('dt-result');
var dtSeconds = document.getElementById('dt-seconds');
var dtMillis = document.getElementById('dt-millis');

// Pre-fill with the current local time
var now = new Date();
dtInput.value = new Date(now - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);

document.getElementById('dt-convert-btn').addEventListener('click', function () {
  var val = dtInput.value;
  if (!val) return;
  var ms = datetimeLocalToMs(val);
  dtSeconds.textContent = Math.floor(ms / 1000);
  dtMillis.textContent = ms;
  dtResult.classList.remove('d-none');
});

document.getElementById('dt-copy-seconds').addEventListener('click', function () {
  copyText(dtSeconds.textContent, this);
});
document.getElementById('dt-copy-millis').addEventListener('click', function () {
  copyText(dtMillis.textContent, this);
});

// --- Epoch → DateTime ---
var epochInput = document.getElementById('epoch-input');
var epochResult = document.getElementById('epoch-result');
var epochUtc = document.getElementById('epoch-utc');
var epochLocal = document.getElementById('epoch-local');
var epochIso = document.getElementById('epoch-iso');

document.getElementById('epoch-convert-btn').addEventListener('click', function () {
  var raw = epochInput.value.trim();
  if (!raw) return;
  var n = parseInt(raw, 10);
  var ms = epochToMs(n);
  var d = new Date(ms);
  epochUtc.textContent = d.toUTCString();
  epochLocal.textContent = d.toLocaleString();
  epochIso.textContent = d.toISOString();
  epochResult.classList.remove('d-none');
});

document.getElementById('epoch-copy-utc').addEventListener('click', function () {
  copyText(epochUtc.textContent, this);
});
document.getElementById('epoch-copy-local').addEventListener('click', function () {
  copyText(epochLocal.textContent, this);
});
document.getElementById('epoch-copy-iso').addEventListener('click', function () {
  copyText(epochIso.textContent, this);
});

// --- Live clock ---
function tick() {
  var t = new Date();
  var ms = t.getTime();
  document.getElementById('now-seconds').textContent = Math.floor(ms / 1000);
  document.getElementById('now-millis').textContent = ms;
  document.getElementById('now-utc').textContent = t.toUTCString();
}
tick();
setInterval(tick, 1000);
</script>

</div>
</div>

<Docs />
</ToolLayout>
