---
//
// Dynamic tool pages: /tools/[tool]/
// Imports each tool's HTML from the existing tools/[id]/index.html files,
// wrapping them in ToolLayout.
//
// Each tool's HTML file already references its own JS (via relative_url filter
// or inline <script type="module"> imports) — no additional script injection needed.

import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import matter from 'gray-matter';
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getTools } from '../../data/index.ts';

// process.cwd() is the Astro project root at both dev and build time
const REPO_ROOT = process.cwd();
const BASE = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const tools = getTools();
  return tools.map(tool => ({
    params: { tool: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;

// Read the existing tool's index.html for its body content
const toolHtmlPath = join(REPO_ROOT, 'tools', tool.id, 'index.html');
let toolBody = '';
try {
  const raw = readFileSync(toolHtmlPath, 'utf8');
  const { content } = matter(raw);
  // Rewrite relative asset URLs to use BASE path
  toolBody = content
    .replace(/href="\.\/([^"]+)"/g, `href="${BASE}tools/${tool.id}/$1"`)
    .replace(/src="\.\/([^"]+)"/g, `src="${BASE}tools/${tool.id}/$1"`)
    // Rewrite relative_url filter syntax that might remain from Jekyll
    .replace(/\{\{ '([^']+)' \| relative_url \}\}/g, (_, path) => `${BASE}${path.replace(/^\//, '')}`);
} catch {
  toolBody = `<p class="text-danger">Tool content not found for <code>${tool.id}</code>.</p>`;
}
---
<ToolLayout title={tool.name} accentColor={tool.accent_color}>
  <Fragment set:html={toolBody} />
</ToolLayout>
