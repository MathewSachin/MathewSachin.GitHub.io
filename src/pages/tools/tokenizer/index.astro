---
import ToolLayout from '@layouts/ToolLayout.astro';
import Docs from '@content/tool-docs/tokenizer.mdx';
const html = `<script src="https://cdn.jsdelivr.net/npm/gpt-tokenizer@2.9.0/dist/o200k_base.js"
  integrity="sha384-c++bciYftVqCv4OqISnwDg8w6AAp4byu4pbHKziESSt788G8QD2kccLmT+ixYwNy"
  crossorigin="anonymous"></script>

<style>
  /* Token visualization colours */
  .tok-a { background: rgba(13, 202, 240, 0.22); border-radius: 2px; }
  .tok-b { background: rgba(255, 193,   7, 0.20); border-radius: 2px; }

  #viz-panel {
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 0.875rem;
    line-height: 1.9;
    white-space: pre-wrap;
    word-break: break-all;
    background: #1a1a2e;
    color: #e0e0e0;
    border-radius: 8px;
    padding: 1rem;
    max-height: 320px;
    overflow-y: auto;
    min-height: 72px;
  }

  .stat-box {
    text-align: center;
    padding: 0.5rem 1.1rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    min-width: 90px;
  }

  .ctx-bar { height: 6px; }
</style>

<div class="card google-anno-skip">
<div class="card-body">

  <!-- Input -->
  <div class="mb-3">
    <label class="form-label fw-semibold" for="text-input">Input Text or Code</label>
    <textarea id="text-input" class="form-control font-monospace" rows="7"
      placeholder="Paste text, code, or a prompt here to see how it tokenizes…"
      aria-label="Text to tokenize"></textarea>
  </div>

  <!-- Stats bar -->
  <div class="d-flex flex-wrap gap-2 mb-3" id="stats-bar" aria-live="polite" aria-atomic="true">
    <div class="stat-box">
      <div class="fs-5 fw-bold text-info" id="stat-tokens">0</div>
      <small class="text-muted">GPT-4o tokens</small>
    </div>
    <div class="stat-box">
      <div class="fs-5 fw-bold" id="stat-chars">0</div>
      <small class="text-muted">characters</small>
    </div>
    <div class="stat-box">
      <div class="fs-5 fw-bold" id="stat-words">0</div>
      <small class="text-muted">words</small>
    </div>
    <div class="stat-box">
      <div class="fs-5 fw-bold text-warning" id="stat-ratio">—</div>
      <small class="text-muted">chars / token</small>
    </div>
  </div>

  <!-- Visualization -->
  <div class="mb-1 d-flex align-items-center justify-content-between flex-wrap gap-1">
    <label class="form-label mb-0 text-muted small">
      GPT-4o token visualization
      <small class="ms-1">(each colour change = one token boundary, o200k_base)</small>
    </label>
    <small id="viz-cap-note" class="text-muted d-none">showing first 5,000 tokens</small>
  </div>
  <div id="viz-panel" aria-live="polite" aria-label="Token visualization">
    <span class="text-muted">Start typing above to see how your text is tokenized.</span>
  </div>

  <hr class="my-4">

  <!-- Cost estimation -->
  <h5 class="mb-2">API Cost Estimation</h5>
  <p class="text-muted small mb-3">
    Prices as of Q1 2025. GPT-4o and Claude 3.5 Sonnet token counts are computed with their
    <strong>actual tokenizers</strong> entirely in your browser.
    Gemini's tokenizer is not publicly available — its count is estimated at ×1.15 from GPT-4o
    based on benchmarks (code and JSON are typically 15% more expensive on Gemini).
    <em>Est. output cost</em> assumes a reply roughly half the length of your input.
  </p>

  <div class="table-responsive">
    <table class="table table-sm table-bordered mb-0">
      <thead class="table-dark">
        <tr>
          <th>Model</th>
          <th class="text-end">Tokens</th>
          <th class="text-end">Input cost</th>
          <th class="text-end">Est. output cost</th>
          <th style="min-width:130px">Context used</th>
        </tr>
      </thead>
      <tbody id="cost-tbody"></tbody>
    </table>
  </div>

</div>
</div>

<script>
(function () {
  'use strict';

  // ── Models & pricing ──────────────────────────────────────────────────────────
  // id:         used for per-model token count storage
  // tokenSrc:   label shown in table under the token count
  // multiplier: fallback when actual tokenizer is unavailable
  var MODELS = [
    { name: 'GPT-4o',            inputPer1M:  2.50, outputPer1M:  10.00, context:  128000, id: 'gpt4o',  tokenSrc: 'o200k_base',  multiplier: 1.00 },
    { name: 'Claude 3.5 Sonnet', inputPer1M:  3.00, outputPer1M:  15.00, context:  200000, id: 'claude', tokenSrc: null,          multiplier: 1.10 },
    { name: 'Gemini 2.0 Flash',  inputPer1M:  0.10, outputPer1M:   0.40, context: 1000000, id: 'gemini', tokenSrc: 'est. ×1.15',  multiplier: 1.15 }
  ];

  // ── Claude tokenizer state ────────────────────────────────────────────────────
  // 'loading' → 'ready' | 'failed'
  var claudeState  = 'loading';
  var claudeEncode = null;  // function(text) → token count when ready

  // Called by the async module script below when the Claude tokenizer is ready
  window.__onClaudeReady = function (encodeFn) {
    claudeEncode = encodeFn;
    claudeState  = 'ready';
    // Re-render the cost table with actual Claude counts
    var text = textInput.value;
    var base = (encodeText && text.length) ? encodeText(text).length : 0;
    updateCostTable(base);
  };
  window.__onClaudeFailed = function () {
    claudeState = 'failed';
    var text = textInput.value;
    var base = (encodeText && text.length) ? encodeText(text).length : 0;
    updateCostTable(base);
  };

  var VIZ_CAP = 5000;
  var COLORS  = ['tok-a', 'tok-b'];

  // ── DOM refs ──────────────────────────────────────────────────────────────────
  var textInput  = document.getElementById('text-input');
  var vizPanel   = document.getElementById('viz-panel');
  var vizCapNote = document.getElementById('viz-cap-note');
  var statTokens = document.getElementById('stat-tokens');
  var statChars  = document.getElementById('stat-chars');
  var statWords  = document.getElementById('stat-words');
  var statRatio  = document.getElementById('stat-ratio');
  var costTbody  = document.getElementById('cost-tbody');

  // ── Helpers ───────────────────────────────────────────────────────────────────
  function escapeHtml(s) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function countWords(text) {
    return text.trim() === '' ? 0 : text.trim().split(/\\s+/).length;
  }

  function formatCost(dollars) {
    if (dollars === 0)         return '$0.00';
    if (dollars < 0.000001)    return '<$0.000001';
    if (dollars < 0.01)        return '$' + dollars.toFixed(6);
    return '$' + dollars.toFixed(4);
  }

  function pctBar(count, context) {
    var pct = Math.min(100, (count / context) * 100);
    var cls = pct > 90 ? 'bg-danger' : pct > 70 ? 'bg-warning' : 'bg-info';
    return (
      '<div class="progress ctx-bar mb-1">' +
        '<div class="progress-bar ' + cls + '" role="progressbar"' +
        ' style="width:' + pct.toFixed(2) + '%"' +
        ' aria-valuenow="' + pct.toFixed(0) + '"' +
        ' aria-valuemin="0" aria-valuemax="100"></div>' +
      '</div>' +
      '<small class="text-muted">' +
        count.toLocaleString() + '\\u202f/\\u202f' +
        (context >= 1000000
          ? (context / 1000000).toFixed(0) + 'M'
          : (context / 1000).toFixed(0) + 'K') +
        '\\u00a0(' + pct.toFixed(1) + '%)' +
      '</small>'
    );
  }

  // ── Tokenizer ─────────────────────────────────────────────────────────────────
  var enc       = window.GPTTokenizer_o200k_base;
  var encodeText = enc ? enc.encode : null;
  var decodeIds  = enc ? enc.decode : null;

  // ── Update ────────────────────────────────────────────────────────────────────
  function update() {
    var text  = textInput.value;
    var chars = text.length;
    var words = countWords(text);

    statChars.textContent = chars.toLocaleString();
    statWords.textContent = words.toLocaleString();

    if (!encodeText) {
      statTokens.textContent = '—';
      statRatio.textContent  = '—';
      vizPanel.innerHTML =
        '<span class="text-warning">' +
        '<i class="fas fa-exclamation-triangle me-1"></i>' +
        'Tokenizer script not loaded. Check your network connection and reload the page.' +
        '</span>';
      return;
    }

    if (chars === 0) {
      statTokens.textContent = '0';
      statRatio.textContent  = '—';
      vizPanel.innerHTML =
        '<span class="text-muted">Start typing above to see how your text is tokenized.</span>';
      vizCapNote.classList.add('d-none');
      updateCostTable(0);
      return;
    }

    var tokenIds = encodeText(text);
    var count    = tokenIds.length;

    statTokens.textContent = count.toLocaleString();
    statRatio.textContent  = (chars / count).toFixed(2);

    // Render visualization (capped)
    var cap  = Math.min(count, VIZ_CAP);
    var html = '';
    for (var i = 0; i < cap; i++) {
      var tokenStr;
      try {
        tokenStr = decodeIds([tokenIds[i]]);
      } catch (e) {
        tokenStr = '\\uFFFD';
      }
      html += '<span class="' + COLORS[i % 2] + '">' + escapeHtml(tokenStr) + '</span>';
    }
    if (count > VIZ_CAP) {
      html += '<span class="text-muted"> \\u2026 (' + (count - VIZ_CAP).toLocaleString() + ' more tokens)</span>';
      vizCapNote.classList.remove('d-none');
    } else {
      vizCapNote.classList.add('d-none');
    }
    vizPanel.innerHTML = html;

    updateCostTable(count);
  }

  function updateCostTable(baseCount) {
    var html = '';
    MODELS.forEach(function (m) {
      var tokenCount, tokenNote;

      if (m.id === 'claude') {
        if (claudeState === 'ready' && claudeEncode) {
          tokenCount = claudeEncode(textInput.value);
          tokenNote  = 'actual (claude.json)';
        } else if (claudeState === 'loading') {
          tokenCount = Math.round(baseCount * m.multiplier);
          tokenNote  = '<span class="spinner-border spinner-border-sm text-secondary me-1" role="status" aria-hidden="true"></span><span class="visually-hidden">Loading tokenizer</span>loading\\u2026';
        } else {
          // failed
          tokenCount = Math.round(baseCount * m.multiplier);
          tokenNote  = 'est. \\u00d71.10 (tokenizer unavailable)';
        }
      } else {
        tokenCount = Math.round(baseCount * m.multiplier);
        tokenNote  = m.tokenSrc;
      }

      var inputCost  = (tokenCount / 1e6) * m.inputPer1M;
      var outputCost = (tokenCount * 0.5 / 1e6) * m.outputPer1M;
      html +=
        '<tr>' +
          '<td><strong>' + m.name + '</strong><br>' +
          '<small class="text-muted">$' + m.inputPer1M.toFixed(2) +
          '\\u202f/\\u202f$' + m.outputPer1M.toFixed(2) + ' per 1\\u202fM tokens in/out</small></td>' +
          '<td class="text-end fw-semibold">' +
            tokenCount.toLocaleString() +
            '<br><small class="text-muted fw-normal">' + tokenNote + '</small></td>' +
          '<td class="text-end fw-semibold">' + formatCost(inputCost) + '</td>' +
          '<td class="text-end">' + formatCost(outputCost) + '</td>' +
          '<td>' + pctBar(tokenCount, m.context) + '</td>' +
        '</tr>';
    });
    costTbody.innerHTML = html;
  }

  // ── Debounced input ───────────────────────────────────────────────────────────
  var debounceTimer;
  function onInput() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(update, 150);
  }
  textInput.addEventListener('input', onInput);

  // ── Seed with example ─────────────────────────────────────────────────────────
  textInput.value =
    'The quick brown fox jumps over the lazy dog.\\n\\n' +
    'AI models use "tokenizers" to split text into chunks before processing. ' +
    'Common words like "the" or "is" are typically one token each. ' +
    'Longer or rarer words like "tokenization" or "WebAssembly" may be split into multiple tokens.';
  updateCostTable(0);
  update();
}());
</script>

<!-- ── Async Claude tokenizer (Anthropic's published vocabulary + tiktoken WASM) ──────── -->
<!-- tiktoken_bg.js and tiktoken_bg.wasm via jsDelivr; claude.json from @anthropic-ai/tokenizer -->
<script type="module">
// Import the tiktoken WASM bindings (pure JS glue code) — SRI applied via fetch integrity below
import * as tiktoken from 'https://cdn.jsdelivr.net/npm/tiktoken@1.0.22/tiktoken_bg.js';

var WASM_URL  = 'https://cdn.jsdelivr.net/npm/tiktoken@1.0.22/tiktoken_bg.wasm';
var VOCAB_URL = 'https://cdn.jsdelivr.net/npm/@anthropic-ai/tokenizer@0.0.4/dist/cjs/claude.json';
var WASM_SRI  = 'sha384-LhZSdpJS87vKuKVPQYSnIsEhM6lCqZLPI/IzPYEKdzOA+1sQcyzuJbBfuSNLU2qH';
var VOCAB_SRI = 'sha384-0/W+OO5/jtFlfeZbfhRHiHgEgTWkh9Er967ebA7jUcG4Tmw6DTyCIlNvJCwzjT8c';

(async function () {
  try {
    // Fetch vocabulary and WASM in parallel; .arrayBuffer() ensures SRI is enforced before compile
    var [vocabResp, wasmBuffer] = await Promise.all([
      fetch(VOCAB_URL, { integrity: VOCAB_SRI }),
      fetch(WASM_URL, { integrity: WASM_SRI }).then(function (r) { return r.arrayBuffer(); })
    ]);

    // Compile + instantiate WASM; the import module name must match wasm-bindgen's convention
    var wasmResult = await WebAssembly.instantiate(wasmBuffer, { './tiktoken_bg.js': tiktoken });

    // Wire WASM exports into the JS glue module
    tiktoken.__wbg_set_wasm(wasmResult.instance.exports);

    var claudeData = await vocabResp.json();
    var t = new tiktoken.Tiktoken(
      claudeData.bpe_ranks,
      claudeData.special_tokens,
      claudeData.pat_str
    );

    if (typeof window.__onClaudeReady === 'function') {
      window.__onClaudeReady(function (text) {
        return t.encode(text.normalize('NFKC'), 'all').length;
      });
    }
  } catch (err) {
    if (typeof window.__onClaudeFailed === 'function') window.__onClaudeFailed();
  }
}());
</script>

`;
---
<ToolLayout title="AI Tokenizer &amp; Cost Calculator" ads={true}>
  <Fragment set:html={html} />
  <Docs />
</ToolLayout>
