---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/cron.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="CRON Expression Generator" ads={true}>

<div class="card google-anno-skip">
<div class="card-body">

<div class="row g-4">

  <!-- Controls -->
  <div class="col-12 col-md-5">
    <h5 class="mb-3">Configure</h5>

    <div class="mb-3">
      <label class="form-label" for="freq-select">Frequency</label>
      <select class="form-select" id="freq-select">
        <option value="minute">Every Minute</option>
        <option value="hour">Hourly</option>
        <option value="day" selected>Daily</option>
        <option value="week">Weekly</option>
        <option value="month">Monthly</option>
      </select>
    </div>

    <!-- Minute-of-hour (hidden for "Every Minute") -->
    <div class="mb-3" id="row-minute">
      <label class="form-label" for="sel-minute">At minute</label>
      <select class="form-select" id="sel-minute"></select>
    </div>

    <!-- Hour-of-day (shown for daily / weekly / monthly) -->
    <div class="mb-3 d-none" id="row-hour">
      <label class="form-label" for="sel-hour">At hour (0–23, UTC)</label>
      <select class="form-select" id="sel-hour"></select>
    </div>

    <!-- Day-of-week (shown for weekly) -->
    <div class="mb-3 d-none" id="row-dow">
      <label class="form-label" for="sel-dow">On day of week</label>
      <select class="form-select" id="sel-dow">
        <option value="0">Sunday</option>
        <option value="1">Monday</option>
        <option value="2">Tuesday</option>
        <option value="3">Wednesday</option>
        <option value="4">Thursday</option>
        <option value="5">Friday</option>
        <option value="6">Saturday</option>
      </select>
    </div>

    <!-- Day-of-month (shown for monthly) -->
    <div class="mb-3 d-none" id="row-dom">
      <label class="form-label" for="sel-dom">On day of month</label>
      <select class="form-select" id="sel-dom"></select>
    </div>
  </div>

  <!-- Result -->
  <div class="col-12 col-md-7">
    <h5 class="mb-3">Expression</h5>

    <div id="result-area" class="d-none">
      <div class="mb-3">
        <label class="form-label fw-semibold">CRON Expression</label>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <code id="cron-expr" class="fs-5"></code>
          <button class="btn btn-sm btn-outline-secondary" id="copy-cron-btn" title="Copy expression">
            <i class="fas fa-copy"></i>
          </button>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Human Readable</label>
        <p id="cron-desc" class="mb-0 text-muted"></p>
      </div>

      <hr>
      <h6 class="mb-2">Field Reference</h6>
      <table class="table table-sm table-bordered">
        <thead class="table-light">
          <tr>
            <th>Field</th>
            <th>Value</th>
            <th>Meaning</th>
          </tr>
        </thead>
        <tbody id="cron-table"></tbody>
      </table>
    </div>
  </div>

</div>

<script>
import { buildCronExpression, ordinal, pad, DOW_NAMES } from '@scripts/tools/cron.js';
import { registerCopyToClipboard } from '@scripts/utils.js';

// ── Populate selects ─────────────────────────────────────────────────────

const selMinute = document.getElementById('sel-minute') as HTMLSelectElement;
const selHour = document.getElementById('sel-hour') as HTMLSelectElement;
const selDom = document.getElementById('sel-dom') as HTMLSelectElement;
const selDow = document.getElementById('sel-dow') as HTMLSelectElement;


for (let m = 0; m < 60; m++) {
  const opt = document.createElement('option');
  opt.value = String(m); opt.textContent = m < 10 ? '0' + m : String(m);
  selMinute.appendChild(opt);
}

for (let h = 0; h < 24; h++) {
  const opt = document.createElement('option');
  opt.value = String(h); opt.textContent = h < 10 ? '0' + h : String(h);
  selHour.appendChild(opt);
}

for (let d = 1; d <= 31; d++) {
  const opt = document.createElement('option');
  opt.value = String(d); opt.textContent = String(d);
  selDom.appendChild(opt);
}

// ── Show / hide rows based on frequency ──────────────────────────────────

const freqSelect = document.getElementById('freq-select') as HTMLSelectElement;
const rowMinute = document.getElementById('row-minute') as HTMLElement;
const rowHour = document.getElementById('row-hour') as HTMLElement;
const rowDow = document.getElementById('row-dow') as HTMLElement;
const rowDom = document.getElementById('row-dom') as HTMLElement;

function updateVisibility() {
  const freq = freqSelect.value;
  rowMinute.classList.toggle('d-none', freq === 'minute');
  rowHour.classList.toggle('d-none', freq === 'minute' || freq === 'hour');
  rowDow.classList.toggle('d-none', freq !== 'week');
  rowDom.classList.toggle('d-none', freq !== 'month');
}

freqSelect.addEventListener('change', function () { updateVisibility(); update(); });
updateVisibility();

// ── Generate ──────────────────────────────────────────────────────────────

function update() {
  const freq = freqSelect.value;
  const min = selMinute.value;
  const hr = selHour.value;
  const dow = selDow.value;
  const dom = selDom.value;

  const result = buildCronExpression(freq, min, hr, dow, dom);
  const expr = result.expr;
  const desc = result.desc;

  let fields: Array<[string,string,string]>;
  if (freq === 'minute') {
    fields = [['Minute','*','Every minute'],['Hour','*','Every hour'],['Day (month)','*','Every day'],['Month','*','Every month'],['Day (week)','*','Every day']];
  } else if (freq === 'hour') {
    fields = [['Minute', min, 'At minute ' + min],['Hour','*','Every hour'],['Day (month)','*','Every day'],['Month','*','Every month'],['Day (week)','*','Every day']];
  } else if (freq === 'day') {
    fields = [['Minute', min, 'At minute ' + min],['Hour', hr, 'At ' + pad(hr) + ':00 UTC'],['Day (month)','*','Every day'],['Month','*','Every month'],['Day (week)','*','Every day']];
  } else if (freq === 'week') {
    fields = [['Minute', min, 'At minute ' + min],['Hour', hr, 'At ' + pad(hr) + ':00 UTC'],['Day (month)','*','Every day'],['Month','*','Every month'],['Day (week)', dow, 'On ' + DOW_NAMES[Number(dow)]]];
  } else { // month
    fields = [['Minute', min, 'At minute ' + min],['Hour', hr, 'At ' + pad(hr) + ':00 UTC'],['Day (month)', dom, 'On the ' + ordinal(+dom)],['Month','*','Every month'],['Day (week)','*','Every day']];
  }

  const cronExprEl = document.getElementById('cron-expr') as HTMLElement;
  const cronDescEl = document.getElementById('cron-desc') as HTMLElement;
  cronExprEl.textContent = expr;
  cronDescEl.textContent  = desc;

  const tbody = document.getElementById('cron-table') as HTMLElement;
  tbody.innerHTML = '';
  fields.forEach(function (f) {
    const tr = document.createElement('tr');
    const tdField = document.createElement('td');
    tdField.textContent = f[0];
    const tdVal = document.createElement('td');
    const code = document.createElement('code');
    code.textContent = f[1];
    tdVal.appendChild(code);
    const tdDesc = document.createElement('td');
    tdDesc.textContent = f[2];
    tr.appendChild(tdField);
    tr.appendChild(tdVal);
    tr.appendChild(tdDesc);
    tbody.appendChild(tr);
  });

  const resultArea = document.getElementById('result-area') as HTMLElement;
  resultArea.classList.remove('d-none');
}

// run update when any control changes
selMinute.addEventListener('change', update);
selHour.addEventListener('change', update);
selDow.addEventListener('change', update);
selDom.addEventListener('change', update);

const copyCronBtn = document.getElementById('copy-cron-btn') as HTMLButtonElement;
const cronElem = document.getElementById('cron-expr') as HTMLElement;
const icon = copyCronBtn.querySelector('i') as HTMLElement;
registerCopyToClipboard(
  copyCronBtn, 
  () => cronElem.textContent || '',
  icon
);

update(); // initial generation
</script>

</div>
</div>

<RenderMDX Content={Content} />
</ToolLayout>
