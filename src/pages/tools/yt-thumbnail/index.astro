---
import ToolLayout from '@layouts/ToolLayout.astro';
import { extractVideoId, thumbnailUrl, getResolutions } from './yt-thumbnail.js';
---
<ToolLayout title="YouTube Thumbnail Grabber" ads={true}>

<div class="card google-anno-skip">
<div class="card-body">

  <div class="mb-3">
    <label for="yt-input" class="form-label fw-semibold">YouTube URL or Video ID</label>
    <input id="yt-input" type="text" class="form-control font-monospace"
      placeholder="https://www.youtube.com/watch?v=dQw4w9WgXcQ">
    <div class="form-text">Paste any YouTube URL (watch, shorts, youtu.be) or just the 11-character video ID.</div>
  </div>
  <button id="grab-btn" class="btn btn-danger text-white">
    <i class="fab fa-youtube me-1"></i>Grab Thumbnail
  </button>
  <div id="yt-error" class="text-danger small mt-2 d-none"></div>

  <div id="yt-result" class="mt-4 d-none">
    <div class="mb-3">
      <img id="yt-preview" alt="YouTube thumbnail preview"
        class="img-fluid rounded border d-block" data-proofer-ignore>
    </div>

    <div class="mb-3">
      <label for="yt-res-select" class="form-label">Resolution</label>
      <select id="yt-res-select" class="form-select" style="max-width:320px;"></select>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <a id="yt-open-btn" href="#" target="_blank" rel="noopener"
        class="btn btn-outline-secondary">
        <i class="fas fa-external-link-alt me-1"></i>Open Image
      </a>
      <button id="yt-download-btn" type="button"
        class="btn btn-primary">
        <i class="fas fa-download me-1"></i>Download
      </button>
    </div>
  </div>

<script type="module">
import { extractVideoId, thumbnailUrl, getResolutions } from './yt-thumbnail.js';

const input    = document.getElementById('yt-input');
const btn      = document.getElementById('grab-btn');
const errEl    = document.getElementById('yt-error');
const result   = document.getElementById('yt-result');
const preview  = document.getElementById('yt-preview');
const resSel   = document.getElementById('yt-res-select');
const openBtn  = document.getElementById('yt-open-btn');
const dlBtn    = document.getElementById('yt-download-btn');

let currentId = null;

// Populate resolution dropdown once
getResolutions().forEach(function (r) {
  const opt = document.createElement('option');
  opt.value = r.key;
  opt.textContent = r.label;
  resSel.appendChild(opt);
});

function showError(msg) {
  errEl.textContent = msg;
  errEl.classList.remove('d-none');
  result.classList.add('d-none');
}

function clearError() {
  errEl.textContent = '';
  errEl.classList.add('d-none');
}

function updatePreview() {
  if (!currentId) return;
  // thumbnailUrl validates the key against the known-safe list
  const url = thumbnailUrl(currentId, resSel.value);
  preview.src = url;
  openBtn.href = url;
  dlBtn.dataset.url = url;
  dlBtn.dataset.filename = 'thumbnail-' + currentId + '-' + resSel.value + '.jpg';
}

btn.addEventListener('click', function () {
  clearError();
  const id = extractVideoId(input.value);
  if (!id) {
    showError('Could not find a valid YouTube video ID. Paste a full YouTube URL or the 11-character video ID.');
    return;
  }
  currentId = id;
  result.classList.remove('d-none');
  updatePreview();
});

resSel.addEventListener('change', updatePreview);

input.addEventListener('keydown', function (e) {
  if (e.key === 'Enter') btn.click();
});

dlBtn.addEventListener('click', function (e) {
  e.preventDefault();
  const url = dlBtn.dataset.url;
  const filename = dlBtn.dataset.filename;
  if (!url) return;
  fetch(url)
    .then(r => r.blob())
    .then(blob => {
      const blobUrl = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = blobUrl;
      a.download = filename;
      a.click();
      setTimeout(() => URL.revokeObjectURL(blobUrl), 60000);
    })
    .catch(() => {
      // Fallback: open in new tab if fetch fails
      window.open(url, '_blank');
    });
});
</script>

</div>
</div>

<div class="card mt-4">
<div class="card-body">

<h4>How It Works</h4>
<p>
  YouTube hosts every video's thumbnail images on publicly accessible, predictable URLs —
  no API key or login required. This tool constructs those URLs from the video ID so you
  can view and save the raw thumbnail instantly.
</p>

<h5 class="mt-4">The URL Pattern</h5>
<p>
  All YouTube thumbnails follow this exact format:
</p>
<pre class="p-3 rounded" style="background:var(--bs-tertiary-bg)"><code>https://img.youtube.com/vi/<strong>&lt;VIDEO_ID&gt;</strong>/<strong>&lt;quality&gt;</strong>.jpg</code></pre>
<p>
  The <code>&lt;VIDEO_ID&gt;</code> is the 11-character string after <code>?v=</code> in any
  YouTube watch URL (e.g. <code>dQw4w9WgXcQ</code>). The <code>&lt;quality&gt;</code>
  segment controls the resolution:
</p>
<div class="table-responsive">
  <table class="table table-sm table-bordered">
    <thead class="table-light">
      <tr><th>Quality key</th><th>Dimensions</th><th>Notes</th></tr>
    </thead>
    <tbody>
      <tr><td><code>maxresdefault</code></td><td>1280 &times; 720</td><td>Highest quality; only available when the video was uploaded at 720p or above</td></tr>
      <tr><td><code>hqdefault</code></td><td>480 &times; 360</td><td>Always available</td></tr>
      <tr><td><code>mqdefault</code></td><td>320 &times; 180</td><td>Always available</td></tr>
      <tr><td><code>default</code></td><td>120 &times; 90</td><td>Smallest; always available</td></tr>
    </tbody>
  </table>
</div>

<h5 class="mt-4">Finding the Video ID</h5>
<p>
  The video ID is the 11-character alphanumeric string that appears after <code>?v=</code> in a
  standard YouTube URL. It also appears after <code>/shorts/</code> or <code>youtu.be/</code>:
</p>
<ul>
  <li><code>youtube.com/watch?v=<strong>dQw4w9WgXcQ</strong></code></li>
  <li><code>youtube.com/shorts/<strong>dQw4w9WgXcQ</strong></code></li>
  <li><code>youtu.be/<strong>dQw4w9WgXcQ</strong></code></li>
</ul>
<p>
  This tool accepts any of those URL formats and extracts the ID automatically. You can also
  paste the bare 11-character ID directly.
</p>

<h5 class="mt-4">Privacy</h5>
<p>
  The ID extraction runs entirely in your browser. The only network request made is directly
  to <code>img.youtube.com</code> to load the thumbnail image — no data passes through any
  third-party server.
</p>

</div>
</div>

</ToolLayout>