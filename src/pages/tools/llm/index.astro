---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/llm.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="Local LLM Chat" ads={true}>

<link rel="modulepreload"
  href="https://cdn.jsdelivr.net/npm/@huggingface/transformers@3.4.1/dist/transformers.min.js"
  integrity="sha384-A5IXc7Kyh0SBF8QiT/5S3QR5bDtgbkOX/xRFggycSY94V0sbZzy3Mi13ou8cUvl8"
  crossorigin="anonymous">

<style>
  #chat-history {
    height: 400px;
    overflow-y: auto;
    background: #e9e9ee;
    border-radius: 8px;
  }
  .chat-bubble-user {
    background: #0dcaf0;
    color: #fff;
    border-radius: 18px 18px 4px 18px;
  }
  .chat-bubble-assistant {
    background: #2d2d2d;
    color: #e0e0e0;
    border-radius: 18px 18px 18px 4px;
  }
  .typing-cursor {
    display: inline-block;
    animation: blink 0.7s step-start infinite;
    margin-left: 1px;
    color: #0dcaf0;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>

<div class="card google-anno-skip">
<div class="card-body">

<!-- Setup -->
<div id="setup-section">
  <div class="row g-3 align-items-end mb-3">

    <div class="col-12 col-sm-7 col-md-6">
      <label class="form-label" for="model-select">Model</label>
      <select class="form-select" id="model-select">
        <option value="Xenova/TinyLlama-1.1B-Chat-v1.0" data-chat="true">TinyLlama 1.1B Chat (~640 MB, recommended)</option>
        <option value="Xenova/gpt2" data-chat="false">GPT-2 (~120 MB, fast — text completion only)</option>
      </select>
    </div>

    <div class="col-auto">
      <button class="btn btn-info text-white" id="load-btn">
        <i class="fas fa-download me-1"></i>Load Model
      </button>
    </div>

  </div>

  <div id="load-progress" class="d-none mb-3">
    <div class="d-flex align-items-center gap-2 mb-1">
      <small id="progress-label" class="text-muted">Loading…</small>
    </div>
    <div class="progress" style="height: 8px;">
      <div id="progress-bar" class="progress-bar bg-info progress-bar-striped progress-bar-animated"
        role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
  </div>
</div>

<!-- Chat -->
<div id="chat-section" class="d-none">

  <div id="chat-history" class="p-3 mb-3" role="log" aria-live="polite" aria-label="Chat history">
    <p class="text-muted text-center small mt-5" id="chat-placeholder">
      <i class="fas fa-robot me-1"></i>Model loaded — say something!
    </p>
  </div>

  <div class="d-flex gap-2 align-items-end">
    <textarea id="chat-input" class="form-control" rows="2"
      placeholder="Type a message and press Enter…" aria-label="Chat input"></textarea>
    <div class="d-flex flex-column gap-2 flex-shrink-0">
      <button class="btn btn-info text-white" id="send-btn" title="Send (Enter)">
        <i class="fas fa-paper-plane"></i>
      </button>
      <button class="btn btn-outline-secondary" id="clear-btn" title="Clear conversation">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  </div>

  <div class="mt-2">
    <small class="text-muted">
      <i class="fas fa-microchip me-1"></i>Runs entirely in your browser via WebAssembly — no data is sent to any server.
      Generation speed depends on your device; first load downloads the model (~0.1 – 0.7 GB, cached after).
    </small>
  </div>

</div>

<!-- Status -->
<div id="status-msg" class="mt-3 d-none"></div>

</div>
</div>

<script type="module" src="/tools/llm/llm.js"></script>

<RenderMDX Content={Content} />
</ToolLayout>
