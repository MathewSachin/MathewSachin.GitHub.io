---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/scratchpad.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="Smart Scratchpad" ads={true}>

<style>
#scratchpad-card:fullscreen {
  border-radius: 0;
  display: flex;
  flex-direction: column;
  padding: 1rem;
  background: var(--bs-body-bg, #fff);
  overflow: hidden;
}
#scratchpad-card:fullscreen .card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
}
#scratchpad-card:fullscreen #scratchpad {
  flex: 1;
  min-height: 0;
  resize: none;
}
</style>

<div class="card google-anno-skip" id="scratchpad-card">
<div class="card-body">

<div class="d-flex align-items-center gap-2 flex-wrap mb-3">
  <button class="btn btn-outline-secondary btn-sm" id="copy-btn">
    <i class="fas fa-copy me-1"></i>Copy All
  </button>
  <button class="btn btn-outline-secondary btn-sm" id="clear-btn">
    <i class="fas fa-trash me-1"></i>Clear
  </button>
  <button class="btn btn-outline-secondary btn-sm" id="fullscreen-btn" title="Toggle full screen">
    <i class="fas fa-expand me-1"></i><span id="fullscreen-label">Full Screen</span>
  </button>
  <span class="ms-auto text-muted small" id="save-status"></span>
  <span class="text-muted small" id="word-count">0 words &middot; 0 chars</span>
</div>

<textarea id="scratchpad" class="form-control font-monospace"
  style="min-height:420px;resize:vertical;font-size:1rem;line-height:1.6;"
  placeholder="Paste or type here — your text is saved automatically…"
  spellcheck="true"
  autocomplete="off"></textarea>

<script>
import { countWords } from '@scripts/tools/scratchpad.js';
import { registerCopyToClipboard } from '@scripts/utils.js';

const STORAGE_KEY: string = 'scratchpad-v1';
const pad = document.getElementById('scratchpad') as HTMLTextAreaElement;
const saveStatus = document.getElementById('save-status') as HTMLElement;
const wordCount = document.getElementById('word-count') as HTMLElement;
const copyBtn = document.getElementById('copy-btn') as HTMLElement;
const clearBtn = document.getElementById('clear-btn') as HTMLElement;
const fsBtn = document.getElementById('fullscreen-btn') as HTMLElement;
const fsLabel = document.getElementById('fullscreen-label') as HTMLElement;
let saveTimer: number | null = null;

// ── Restore saved content ─────────────────────────────────────────────────
try {
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved !== null && pad) {
    pad.value = saved;
  }
} catch (e) { /* private browsing / storage disabled */ }

// ── Helpers ───────────────────────────────────────────────────────────────
function updateCount() {
  const text = pad ? pad.value : '';
  const chars = text.length;
  const words = countWords(text);
  const wordLabel = words + ' word' + (words !== 1 ? 's' : '');
  const charLabel = chars + ' char' + (chars !== 1 ? 's' : '');
  wordCount.textContent = wordLabel + ' \u00b7 ' + charLabel;
}

function persistContent() {
  try {
    localStorage.setItem(STORAGE_KEY, pad.value);
    saveStatus.textContent = 'Saved';
    saveStatus.style.color = '';
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = window.setTimeout(function () { saveStatus.textContent = ''; }, 2000);
  } catch (e) {
    saveStatus.textContent = 'Could not save';
    saveStatus.style.color = 'var(--bs-danger, #dc3545)';
  }
}

// ── Auto-save on every keystroke ──────────────────────────────────────────
pad.addEventListener('input', function () {
  updateCount();
  persistContent();
});

// ── Copy All ──────────────────────────────────────────────────────────────
registerCopyToClipboard(copyBtn, () => pad.value, copyBtn.querySelector('i'));

// ── Clear ─────────────────────────────────────────────────────────────────
clearBtn.addEventListener('click', function () {
  if (pad.value !== '' && !window.confirm('Clear all text?')) return;
  pad.value = '';
  updateCount();
  persistContent();
  pad.focus();
});

// ── Full-screen ───────────────────────────────────────────────────────────
fsBtn.addEventListener('click', function () {
  var card = document.getElementById('scratchpad-card') as HTMLElement;
  if (!document.fullscreenElement) {
    if (card.requestFullscreen) { card.requestFullscreen(); }
  } else {
    if (document.exitFullscreen) { document.exitFullscreen(); }
  }
});

document.addEventListener('fullscreenchange', function () {
  var icon = fsBtn.querySelector('i') as HTMLElement;
  if (document.fullscreenElement) {
    icon.className = 'fas fa-compress me-1';
    fsLabel.textContent = 'Exit Full Screen';
  } else {
    icon.className = 'fas fa-expand me-1';
    fsLabel.textContent = 'Full Screen';
  }
});

// ── Initial count ─────────────────────────────────────────────────────────
updateCount();
</script>

</div>
</div>

<RenderMDX Content={Content} />
</ToolLayout>
