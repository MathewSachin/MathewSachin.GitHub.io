---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/imgcompress.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="Image Compressor" ads={true}>
  <script is:inline src="https://unpkg.com/@imagemagick/magick-wasm@0.0.39/dist/index.umd.cjs"
  integrity="sha384-M8gIiLd+UKUmTrqlRrO14Veff1ao4UoVqgcMhovIW5DUwxErdsz8K+6D3ZbplaNN"
  crossorigin="anonymous"></script>

<div class="card google-anno-skip">
<div class="card-body">

<!-- Drop zone / file picker -->
<div id="drop-zone" class="border border-2 rounded p-5 text-center mb-4"
  style="cursor:pointer; border-style:dashed !important">
  <i class="fas fa-image fa-2x text-muted mb-2 d-block"></i>
  <p class="mb-1">Drop an image here, or <span class="text-info">click to browse</span></p>
  <small class="text-muted">JPEG · PNG · WebP · GIF · BMP</small>
  <input type="file" id="file-input" accept="image/*" class="d-none">
</div>

<div id="options-section" class="d-none">

  <div class="row g-3 align-items-end mb-3">

    <!-- Output format -->
    <div class="col-12 col-sm-4 col-md-3">
      <label class="form-label" for="output-format">Output Format</label>
      <select class="form-select" id="output-format">
        <option value="JPEG">JPEG</option>
        <option value="PNG">PNG</option>
        <option value="WEBP">WebP</option>
      </select>
    </div>

    <!-- Quality -->
    <div class="col-12 col-sm-8 col-md-5" id="quality-section">
      <label class="form-label" for="quality-slider">
        Quality: <span id="quality-value">80</span>%
      </label>
      <input type="range" class="form-range" id="quality-slider" min="1" max="100" value="80">
    </div>

    <!-- Resize -->
    <div class="col-12 col-md-4">
      <div class="form-check mb-1">
        <input class="form-check-input" type="checkbox" id="resize-check">
        <label class="form-check-label" for="resize-check">Limit max width</label>
      </div>
      <input type="number" class="form-control" id="max-width" value="1920" min="1" max="99999" disabled
        aria-label="Max width in pixels">
      <small class="text-muted">pixels</small>
    </div>

  </div>

  <button class="btn btn-info text-white" id="compress-btn">
    <i class="fas fa-compress-alt me-1"></i>Compress Image
  </button>

</div>

<!-- Status -->
<div id="status-msg" class="mt-3 d-none"></div>

<!-- Results -->
<div id="results-section" class="d-none mt-4">
  <div class="row g-4">

    <div class="col-12 col-md-6">
      <h6 class="text-muted mb-2">Original</h6>
      <img id="preview-original" class="img-fluid rounded border" alt="Original image preview" data-proofer-ignore>
      <p class="mt-2 text-muted small" id="info-original"></p>
    </div>

    <div class="col-12 col-md-6">
      <h6 class="text-muted mb-2">Compressed</h6>
      <img id="preview-compressed" class="img-fluid rounded border" alt="Compressed image preview" data-proofer-ignore>
      <p class="mt-2 text-muted small" id="info-compressed"></p>
    </div>

  </div>

  <div class="mt-3 d-flex align-items-center gap-3 flex-wrap">
    <button class="btn btn-success" id="download-btn">
      <i class="fas fa-download me-1"></i>Download
    </button>
    <span id="savings-label" class="fw-semibold"></span>
  </div>
</div>

<script>
(function () {
  let initialized: boolean = false;
  let initializing: boolean = false;
  let originalFile: File | null = null;
  let compressedBlob: Blob | null = null;
  let compressedFilename: string = '';

  const dropZone = document.getElementById('drop-zone') as HTMLElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const optionsSection = document.getElementById('options-section') as HTMLElement;
  const outputFormat = document.getElementById('output-format') as HTMLSelectElement;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityValue = document.getElementById('quality-value') as HTMLElement;
  const qualitySection = document.getElementById('quality-section') as HTMLElement;
  const resizeCheck = document.getElementById('resize-check') as HTMLInputElement;
  const maxWidthInput = document.getElementById('max-width') as HTMLInputElement;
  const compressBtn = document.getElementById('compress-btn') as HTMLButtonElement;
  const statusMsg = document.getElementById('status-msg') as HTMLElement;
  const resultsSection = document.getElementById('results-section') as HTMLElement;
  const previewOrig = document.getElementById('preview-original') as HTMLImageElement;
  const previewComp = document.getElementById('preview-compressed') as HTMLImageElement;
  const infoOrig = document.getElementById('info-original') as HTMLElement;
  const infoComp = document.getElementById('info-compressed') as HTMLElement;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
  const savingsLabel = document.getElementById('savings-label') as HTMLElement;

  function formatBytes(b: number) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(2) + ' MB';
  }

  function showStatus(html: string, type?: string) {
    statusMsg.innerHTML = '<div class="alert alert-' + (type || 'info') + ' py-2 mb-0">' + html + '</div>';
    statusMsg.classList.remove('d-none');
  }

  function hideStatus() { statusMsg.classList.add('d-none'); }

  // Quality slider label
  qualitySlider.addEventListener('input', function () {
    qualityValue.textContent = this.value;
  });

  // Disable quality for PNG (lossless)
  outputFormat.addEventListener('change', function () {
    var isPng = this.value === 'PNG';
    qualitySection.style.opacity = isPng ? '0.5' : '1';
    qualitySlider.disabled = isPng;
  });

  // Toggle max-width input
  resizeCheck.addEventListener('change', function () {
    maxWidthInput.disabled = !this.checked;
  });

  // Drop zone interaction
  dropZone.addEventListener('click', function () { fileInput.click(); });

  dropZone.addEventListener('dragover', function (e: DragEvent) {
    e.preventDefault();
    dropZone.classList.add('border-info');
  });

  dropZone.addEventListener('dragleave', function () {
    dropZone.classList.remove('border-info');
  });

  dropZone.addEventListener('drop', function (e: DragEvent) {
    e.preventDefault();
    dropZone.classList.remove('border-info');
    if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
  });

  fileInput.addEventListener('change', function () {
    if (this.files?.[0]) handleFile(this.files[0]);
  });

  function handleFile(file: File) {
    if (!file.type || !file.type.startsWith('image/')) {
      showStatus('Please select an image file.', 'danger');
      return;
    }
    originalFile = file;
    compressedBlob = null;
    resultsSection.classList.add('d-none');
    hideStatus();

    const url = URL.createObjectURL(file);
    previewOrig.src = url;
    previewOrig.onload = function () {
      infoOrig.textContent =
        file.name + '  —  ' +
        formatBytes(file.size) + '  —  ' +
        previewOrig.naturalWidth + ' × ' + previewOrig.naturalHeight + ' px';
    };

    // Pre-select output format matching input
    if (file.type === 'image/png') {
      outputFormat.value = 'PNG';
    } else if (file.type === 'image/webp') {
      outputFormat.value = 'WEBP';
    } else {
      outputFormat.value = 'JPEG';
    }
    outputFormat.dispatchEvent(new Event('change'));

    optionsSection.classList.remove('d-none');
  }

  compressBtn.addEventListener('click', function () {
    if (!originalFile) return;
    const reader = new FileReader();
    reader.onload = function (e: ProgressEvent<FileReader>) {
      const arr = e.target?.result ? e.target.result as ArrayBuffer : null;
      if (!arr) { showStatus('Failed to read file.', 'danger'); return; }
      const data = new Uint8Array(arr);
      ensureInitialized(function () { compress(data); });
    };
    reader.readAsArrayBuffer(originalFile);
  });

  function ensureInitialized(cb: () => void) {
    if (initialized) { cb(); return; }
    if (initializing) return;
    initializing = true;
    showStatus('<i class="fas fa-spinner fa-spin me-2"></i>Loading ImageMagick — this may take a moment on first use…');
    const M: any = (window as any)['magick-wasm'];
    // Pre-fetch the WASM binary ourselves so the browser's fetch() follows CDN
    // redirects correctly; passing a raw Uint8Array avoids Emscripten's internal
    // fetch path that can return an empty buffer on some CDN configurations.
    fetch('https://unpkg.com/@imagemagick/magick-wasm@0.0.39/dist/magick.wasm')
      .then(function (r) { return r.arrayBuffer(); })
      .then(function (buf) { return M.initializeImageMagick(new Uint8Array(buf)); })
      .then(function () {
        initialized = true;
        initializing = false;
        hideStatus();
        cb();
      })
      .catch(function (err: any) {
        initializing = false;
        showStatus('Failed to load ImageMagick: ' + (err instanceof Error ? err.message : String(err)), 'danger');
      });
  }

  function compress(inputData: Uint8Array) {
    const M: any = (window as any)['magick-wasm'];
    const fmt = outputFormat.value;
    const quality = parseInt(qualitySlider.value, 10);
    const doResize = resizeCheck.checked;
    const mxw = Math.max(1, parseInt(maxWidthInput.value || '1920', 10) || 1920);

    compressBtn.disabled = true;
    showStatus('<i class="fas fa-spinner fa-spin me-2"></i>Compressing…');

    // Defer to next tick so the browser can render the spinner
    setTimeout(function () {
      try {
        const orig = originalFile;
        if (!orig) {
          showStatus('No source file available.', 'danger');
          compressBtn.disabled = false;
          return;
        }

        M.ImageMagick.read(inputData, function (image: any) {
          if (fmt !== 'PNG') {
            image.quality = quality;
          }

          if (doResize && image.width > mxw) {
            const ratio     = mxw / image.width;
            const newHeight = Math.round(image.height * ratio);
            image.resize(mxw, newHeight);
          }

          const magickFmt = fmt === 'JPEG' ? M.MagickFormat.Jpeg
                        : fmt === 'WEBP' ? M.MagickFormat.WebP
                        : M.MagickFormat.Png;

          image.write(magickFmt, function (data: any) {
            const ext  = fmt === 'JPEG' ? 'jpg' : fmt.toLowerCase();
            const mime = fmt === 'JPEG' ? 'image/jpeg'
                     : fmt === 'WEBP' ? 'image/webp'
                     : 'image/png';
            const blob     = new Blob([data], { type: mime });
            const baseName = orig.name.replace(/\.[^.]+$/, '');
            compressedFilename = baseName + '-compressed.' + ext;
            compressedBlob     = blob;

            previewComp.src = URL.createObjectURL(blob);
            previewComp.onload = function () {
              infoComp.textContent =
                compressedFilename + '  —  ' +
                formatBytes(blob.size) + '  —  ' +
                previewComp.naturalWidth + ' × ' + previewComp.naturalHeight + ' px';
            };

            const diff = orig.size - blob.size;
            const pct = ((diff / orig.size) * 100).toFixed(1); // string
            if (diff > 0) {
              savingsLabel.textContent = pct + '% smaller (' + formatBytes(diff) + ' saved)';
              savingsLabel.className = 'fw-semibold text-success';
            } else {
              const pctNum = Math.abs(parseFloat(pct) || 0).toFixed(1);
              savingsLabel.textContent = pctNum + '% larger than original';
              savingsLabel.className = 'fw-semibold text-warning';
            }

            resultsSection.classList.remove('d-none');
            hideStatus();
            compressBtn.disabled = false;
          });
        });
      } catch (err: any) {
        showStatus('Compression failed: ' + (err instanceof Error ? err.message : String(err)), 'danger');
        compressBtn.disabled = false;
      }
    }, 50);
  }

  downloadBtn.addEventListener('click', function () {
    if (!compressedBlob) return;
    const a = document.createElement('a');
    a.href = URL.createObjectURL(compressedBlob);
    a.download = compressedFilename;
    a.click();
  });
}());
</script>

</div>
</div>

<RenderMDX Content={Content} />
</ToolLayout>
