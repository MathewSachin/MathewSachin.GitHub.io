---
import ToolLayout from '@layouts/ToolLayout.astro';
import { Content } from '@content/tool-docs/json.mdx';
import RenderMDX from '@components/mdx/RenderMDX.astro';
---
<ToolLayout title="JSON Formatter & Validator" ads={true}>

<div class="card google-anno-skip">
<div class="card-body">

<div class="row g-4">
  <div class="col-12 col-md-6">
    <label class="form-label fw-semibold" for="json-input">Input</label>
    <textarea id="json-input" class="form-control font-monospace" rows="14"
      placeholder='{"key":"value"}'></textarea>
    <div class="mt-2 d-flex gap-2 flex-wrap">
      <button class="btn btn-info text-white" id="json-format-btn">Format</button>
      <button class="btn btn-outline-secondary" id="json-minify-btn">Minify</button>
      <button class="btn btn-outline-secondary" id="json-clear-btn">Clear</button>
    </div>
    <div id="json-error" class="alert alert-danger mt-2 py-2 d-none" role="alert"></div>
    <div id="json-ok" class="alert alert-success mt-2 py-2 d-none" role="alert">
      <i class="fas fa-check-circle me-1"></i>Valid JSON
    </div>
  </div>
  <div class="col-12 col-md-6">
    <label class="form-label fw-semibold" for="json-output">Output</label>
    <textarea id="json-output" class="form-control font-monospace" rows="14"
      readonly placeholder="Formatted output…"></textarea>
    <div class="mt-2">
      <button class="btn btn-outline-secondary" id="json-copy-btn">
        <i class="fas fa-copy me-1"></i>Copy
      </button>
    </div>
  </div>
</div>

<script>
import { formatJson } from '@scripts/tools/json-formatter.js';
import { registerCopyToClipboard } from '@scripts/utils.js';

const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
const jsonOutput = document.getElementById('json-output') as HTMLTextAreaElement;
const jsonError = document.getElementById('json-error') as HTMLElement;
const jsonOk = document.getElementById('json-ok') as HTMLElement;

function clearFeedback() {
  jsonError.textContent = '';
  jsonError.classList.add('d-none');
  jsonOk.classList.add('d-none');
}

function applyFormat(indent: number) {
  clearFeedback();
  const result = formatJson(jsonInput.value, indent);
  if (result.error) {
    jsonOutput.value = '';
    jsonError.textContent = result.error;
    jsonError.classList.remove('d-none');
  } else {
    jsonOutput.value = result.output;
    if (result.output) jsonOk.classList.remove('d-none');
  }
}

const fmtBtn = document.getElementById('json-format-btn') as HTMLButtonElement;
const minBtn = document.getElementById('json-minify-btn') as HTMLButtonElement;
const clrBtn = document.getElementById('json-clear-btn') as HTMLButtonElement;
fmtBtn.addEventListener('click', function () { applyFormat(2); });
minBtn.addEventListener('click', function () { applyFormat(0); });
clrBtn.addEventListener('click', function () {
  jsonInput.value = ''; jsonOutput.value = '';
  clearFeedback();
});

const jsonCopyBtn = document.getElementById('json-copy-btn') as HTMLElement;
const jsonCopyIcon = jsonCopyBtn.querySelector('i') as HTMLElement;
registerCopyToClipboard(jsonCopyBtn, () => jsonOutput.value, jsonCopyIcon);
</script>

</div>
</div>

<RenderMDX Content={Content} />
</ToolLayout>
