---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ToolLayout from '@layouts/ToolLayout.astro';
import Base64Tool from '@components/tools/Base64Tool.svelte';
import Bookmarklet from '@components/tools/Bookmarklet.svelte';
import CapturaWebRecorder from '@components/tools/CapturaWebRecorder.svelte';
import CronTool from '@components/tools/CronTool.svelte';
import DiffTool from '@components/tools/DiffTool.svelte';
import HashTool from '@components/tools/HashTool.svelte';
import ImageCompressor from '@components/tools/ImageCompressor.svelte';
import IonTool from '@components/tools/IonTool.svelte';
import JsonTool from '@components/tools/JsonTool.svelte';
import LocalAI from '@components/tools/LocalAI.svelte';
import MediaConverter from '@components/tools/MediaConverter.svelte';
import PdfPasswordTool from '@components/tools/PdfPasswordTool.svelte';
import Scratchpad from '@components/tools/Scratchpad.svelte';
import TimestampTool from '@components/tools/TimestampTool.svelte';
import YtThumbnail from '@components/tools/YtThumbnail.svelte';

export async function getStaticPaths() {
  const entries = await getCollection('toolDocs', ({ data }) => data.published && !!data.component && !!data.title);

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'toolDocs'> };

if (entry.data.component === 'captura') {
  await import('@styles/recorder.css');
}

const { Content } = await render(entry);
const BASE = import.meta.env.BASE_URL;
---
<ToolLayout
  title={entry.data.title!}
  accentColor={entry.data.accent_color}
  ads={entry.data.ads}
  manifest={entry.data.manifest}
  DescriptiveContent={Content}
>
  {entry.data.component === 'base64' && <Base64Tool client:load />}
  {entry.data.component === 'bookmarklet' && <Bookmarklet client:load />}
  {entry.data.component === 'captura' && <CapturaWebRecorder client:load client:only />}
  {entry.data.component === 'cron' && <CronTool client:load />}
  {entry.data.component === 'diff' && <DiffTool client:load />}
  {entry.data.component === 'hash' && <HashTool client:load />}
  {entry.data.component === 'imgcompress' && <ImageCompressor client:load />}
  {entry.data.component === 'ion' && <IonTool client:load />}
  {entry.data.component === 'json' && <JsonTool client:load />}
  {entry.data.component === 'localai' && <LocalAI client:only="svelte" />}
  {entry.data.component === 'mediaconvert' && <MediaConverter client:load />}
  {entry.data.component === 'pdf' && <PdfPasswordTool client:load workerUrl={`${BASE}tools/pdf/pdf.worker.js`} />}
  {entry.data.component === 'scratchpad' && <Scratchpad client:load client:only />}
  {entry.data.component === 'timestamp' && <TimestampTool client:load />}
  {entry.data.component === 'yt-thumbnail' && <YtThumbnail client:load />}
</ToolLayout>
