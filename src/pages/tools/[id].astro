---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import ToolLayout from '@layouts/ToolLayout.astro';
import Base64Renderer from '@components/tools/renderers/Base64Renderer.astro';
import BookmarkletRenderer from '@components/tools/renderers/BookmarkletRenderer.astro';
import CapturaRenderer from '@components/tools/renderers/CapturaRenderer.astro';
import CronRenderer from '@components/tools/renderers/CronRenderer.astro';
import DiffRenderer from '@components/tools/renderers/DiffRenderer.astro';
import HashRenderer from '@components/tools/renderers/HashRenderer.astro';
import ImageCompressorRenderer from '@components/tools/renderers/ImageCompressorRenderer.astro';
import IonRenderer from '@components/tools/renderers/IonRenderer.astro';
import JsonRenderer from '@components/tools/renderers/JsonRenderer.astro';
import LocalAIRenderer from '@components/tools/renderers/LocalAIRenderer.astro';
import MediaConverterRenderer from '@components/tools/renderers/MediaConverterRenderer.astro';
import PdfRenderer from '@components/tools/renderers/PdfRenderer.astro';
import ScratchpadRenderer from '@components/tools/renderers/ScratchpadRenderer.astro';
import TimestampRenderer from '@components/tools/renderers/TimestampRenderer.astro';
import YtThumbnailRenderer from '@components/tools/renderers/YtThumbnailRenderer.astro';

const TOOL_RENDERERS: Record<string, AstroComponentFactory> = {
  base64: Base64Renderer,
  bookmarklet: BookmarkletRenderer,
  captura: CapturaRenderer,
  cron: CronRenderer,
  diff: DiffRenderer,
  hash: HashRenderer,
  imgcompress: ImageCompressorRenderer,
  ion: IonRenderer,
  json: JsonRenderer,
  localai: LocalAIRenderer,
  mediaconvert: MediaConverterRenderer,
  pdf: PdfRenderer,
  scratchpad: ScratchpadRenderer,
  timestamp: TimestampRenderer,
  'yt-thumbnail': YtThumbnailRenderer,
};

export async function getStaticPaths() {
  const entries = await getCollection('toolDocs', ({ data }) => data.published && !!data.component && !!data.title);

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'toolDocs'> };
const ToolRenderer = entry.data.component ? TOOL_RENDERERS[entry.data.component] : undefined;

if (!ToolRenderer) {
  throw new Error(`Missing tool renderer for: ${entry.id}`);
}

const { Content } = await render(entry);
---
<ToolLayout
  title={entry.data.title!}
  accentColor={entry.data.accent_color}
  ads={entry.data.ads}
  manifest={entry.data.manifest}
  DescriptiveContent={Content}
>
  <ToolRenderer />
</ToolLayout>
