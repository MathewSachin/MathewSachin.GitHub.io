---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import ToolLayout from '@layouts/ToolLayout.astro';
import Base64Tool from '@components/tools/Base64Tool.svelte';
import Bookmarklet from '@components/tools/Bookmarklet.svelte';
import CapturaWebRecorder from '@components/tools/CapturaWebRecorder.svelte';
import CronTool from '@components/tools/CronTool.svelte';
import DiffTool from '@components/tools/DiffTool.svelte';
import HashTool from '@components/tools/HashTool.svelte';
import ImageCompressor from '@components/tools/ImageCompressor.svelte';
import IonTool from '@components/tools/IonTool.svelte';
import JsonTool from '@components/tools/JsonTool.svelte';
import LocalAI from '@components/tools/LocalAI.svelte';
import MediaConverter from '@components/tools/MediaConverter.svelte';
import PdfPasswordTool from '@components/tools/PdfPasswordTool.svelte';
import Scratchpad from '@components/tools/Scratchpad.svelte';
import TimestampTool from '@components/tools/TimestampTool.svelte';
import YtThumbnail from '@components/tools/YtThumbnail.svelte';

const TOOL_COMPONENTS: Record<string, AstroComponentFactory> = {
  base64: Base64Tool,
  bookmarklet: Bookmarklet,
  captura: CapturaWebRecorder,
  cron: CronTool,
  diff: DiffTool,
  hash: HashTool,
  imgcompress: ImageCompressor,
  ion: IonTool,
  json: JsonTool,
  localai: LocalAI,
  mediaconvert: MediaConverter,
  pdf: PdfPasswordTool,
  scratchpad: Scratchpad,
  timestamp: TimestampTool,
  'yt-thumbnail': YtThumbnail,
};

const CLIENT_ONLY_COMPONENTS = new Set(['localai', 'scratchpad']);

export async function getStaticPaths() {
  const entries = await getCollection('toolDocs', ({ data }) => data.published);

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'toolDocs'> };

if (!entry.data.component) {
  throw new Error(`Published tool is missing component metadata: ${entry.id}`);
}

const toolComponentKey = entry.data.component;
const ToolComponent = TOOL_COMPONENTS[toolComponentKey];

if (!ToolComponent) {
  throw new Error(`Missing tool component mapping for: ${entry.id}`);
}

if (toolComponentKey === 'captura') {
  await import('@styles/recorder.css');
}

const { Content } = await render(entry);
const toolTitle = entry.data.title ?? entry.id;
const BASE = import.meta.env.BASE_URL;
const toolProps = toolComponentKey === 'pdf' ? { workerUrl: `${BASE}tools/pdf/pdf.worker.js` } : undefined;
const isClientOnly = CLIENT_ONLY_COMPONENTS.has(toolComponentKey);
---
<ToolLayout
  title={toolTitle}
  accentColor={entry.data.accent_color}
  ads={entry.data.ads}
  manifest={entry.data.manifest}
  DescriptiveContent={Content}
>
  {isClientOnly ? (
    <ToolComponent {...toolProps} client:only="svelte" />
  ) : (
    <ToolComponent {...toolProps} client:load />
  )}
</ToolLayout>
