---
import GoogleAnalytics from '@components/GoogleAnalytics.astro';
import Navbar from '@components/Navbar.astro';
import '@styles/styles.css';
import '@fortawesome/fontawesome-free/css/all.min.css';
import 'bootstrap/dist/css/bootstrap.min.css';

/**
 * BaseLayout.astro
 * Replaces _layouts/default.html + _includes/head.html + _includes/navbar.html
 */
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  accentColor?: string;
  manifest?: string;
  ads?: boolean;
  feedUrl?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage,
  accentColor,
  manifest,
  ads = false,
  feedUrl,
  canonicalUrl,
} = Astro.props;

const ADSENSE_ID = import.meta.env.PUBLIC_ADSENSE_ID || 'ca-pub-4251360406988977';
const IS_PROD = import.meta.env.PROD;
const BASE = import.meta.env.BASE_URL;

const pageTitle = title ? title : 'Blog | Mathew Sachin';
const siteUrl = 'https://mathewsachin.github.io';
const resolvedCanonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en-us">
<head>
  <GoogleAnalytics />

  <meta charset="UTF-8" />
  <title>{pageTitle}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {description && <meta name="description" content={description} />}

  <link rel="icon" href={`${BASE}images/favicon.ico`} />
  <link rel="canonical" href={resolvedCanonical} />

  {/* OpenGraph */}
  <meta property="og:title" content={pageTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={resolvedCanonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:site" content="@MathewSachin7" />


  {manifest && <link rel="manifest" href={`${BASE}${manifest}`} />}

  {/* RSS Feed */}
  {feedUrl && <link rel="alternate" type="application/rss+xml" title="Mathew Sachin Blog" href={feedUrl} />}
  {!feedUrl && <link rel="alternate" type="application/rss+xml" title="Mathew Sachin Blog" href={`${BASE}feed.xml`} />}

  {/* AdSense */}
  {IS_PROD && ads && (
    <script data-ad-client={ADSENSE_ID} async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
  )}

  {accentColor && <style define:vars={{ accentColor }}>{`:root { --post-accent: ${accentColor}; }`}</style>}

  <slot name="head" />
</head>
<body class="bg-dark">
  <Navbar />
  <slot />

  <script src='@scripts/formatting.js'></script>
</body>
</html>

