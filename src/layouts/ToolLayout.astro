---
/**
 * ToolLayout.astro
 * Replaces _layouts/tool.html
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Share from '@components/Share.astro';
import AdUnit from '@components/AdUnit.astro';
import Giscus from '@components/Giscus.astro';

interface Props {
  title: string;
  accentColor?: string;
  ads?: boolean;
  manifest?: string;
}

const { title, accentColor, ads = true, manifest } = Astro.props;
const pageUrl = Astro.url.href;
---
<BaseLayout title={title} accentColor={accentColor} ads={ads} manifest={manifest}>
  <div class="bg-dark">
    <div
      id="tool-header"
      class="py-4 text-white google-anno-skip"
      style={accentColor ? `background-color: ${accentColor};` : undefined}
    >
      <div class="container">
        <h2>{title}</h2>
        <Share title={title} url={pageUrl} btnClass="btn-outline-light" labelClass="text-white" />
      </div>
    </div>

    <br />

    <div class="container">
      <div class="row">
        <div id="tool-main-content" class="col-md-10">
          <div class="page-content">
            <slot />
          </div>
        </div>
        <div id="tool-sidebar" class="col-md-2">
          <div class="sticky-top" style="top: 10px">
            <AdUnit />
          </div>
        </div>
      </div>
    </div>

    <br />

    <div id="tool-giscus-section" class="container">
      <div class="row">
        <div class="col-md-10">
          <div class="card">
            <div class="card-body">
              <Giscus />
            </div>
          </div>
        </div>
      </div>
    </div>

    <br />
  </div>
</BaseLayout>
