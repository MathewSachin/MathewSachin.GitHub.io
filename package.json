{
  "name": "mathewsachin-blog",
  "private": true,
  "type": "module",
  "scripts": {
    "build-search-index": "node scripts/build-search-index.js",
    "bundle-orama": "esbuild --bundle --format=esm --minify --outfile=scripts/orama.js node_modules/@orama/orama/dist/browser/index.js",
    "build": "npm run build:ts && npm run bundle-orama && npm run build-search-index",
    "test": "npm run build:ts && node --test tests/*.test.mjs",
    "test:ruby": "bundle exec rspec spec/ --format documentation",
    "test:e2e": "playwright test",
    "build:ts": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@pintora/standalone": "^0.8.1",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.4",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2"
  }
}
